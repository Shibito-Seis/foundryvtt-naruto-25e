<form class="naruto-technique-importer">
  <section class="naruto-importer-section">
    <h2>Import des données Naruto 2.5e</h2>

    <p class="muted">
      Cet outil importe les fichiers JSON déclarés dans le système vers les compendiums correspondants :
      techniques, pouvoirs de lignée et équipements.
    </p>

    <div class="form-group">
      <label>
        <input type="checkbox" name="clear" checked>
        Vider les compendiums ciblés avant import
      </label>
      <p class="notes">
        Recommandé pendant le développement : cela évite les doublons après modification des fichiers JSON.
        Les compendiums alimentés par plusieurs fichiers ne sont vidés qu’une seule fois.
      </p>
    </div>

    <hr>

    <h3>Sources déclarées</h3>

    {{#each sourceGroups as |group|}}
      <section class="naruto-importer-source-group">
        <h4>{{group.label}}</h4>

        <ul>
          {{#each group.sources as |source|}}
            <li>
              <strong>{{source.pack}}</strong><br>
              <span class="muted">{{source.path}}</span>
            </li>
          {{/each}}
        </ul>
      </section>
    {{/each}}
  </section>

  <footer class="sheet-footer flexrow">
    <button type="submit">
      <i class="fas fa-file-import"></i>
      Importer les données
    </button>
  </footer>
</form>