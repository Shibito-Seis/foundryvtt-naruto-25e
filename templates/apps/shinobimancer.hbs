<section class="shinobimancer-shell shinobimancer-main">
  <header class="shinobimancer-topbar">
    <div>
      <p class="shinobimancer-kicker">Dossier officiel de Shinobi</p>
      <h1>Shinobimancer</h1>
    </div>

    <div class="shinobimancer-topbar-actor">
      <img src="{{actorImg}}" alt="{{actorName}}" />
      <div>
        <strong>{{actorName}}</strong>
        <span>Création guidée</span>
      </div>
    </div>
  </header>

  <div class="shinobimancer-layout">
    <aside class="shinobimancer-sidebar">
      <div class="shinobimancer-binding-title">
        <span>Étapes</span>
      </div>

      <nav class="shinobimancer-step-list">
        {{#each steps as |step|}}
          <button type="button" class="shinobimancer-step {{step.cssClass}}" data-step="{{step.key}}">
            <span class="shinobimancer-step-seal">
              {{step.number}}
            </span>

            <span class="shinobimancer-step-text">
              <strong>{{step.shortLabel}}</strong>
              <span>{{step.description}}</span>
            </span>
          </button>
        {{/each}}
      </nav>
    </aside>

    <main class="shinobimancer-content">
      <section class="shinobimancer-page-header">
        <p class="shinobimancer-kicker">Étape {{activeStep.number}}</p>
        <h2>{{activeStep.label}}</h2>
        <p>{{activeStep.description}}</p>
      </section>

      {{#if (eq currentStep "identity")}}
        <section class="shinobimancer-panel shinobimancer-identity-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Registre d’identité</p>
              <h3>Premiers éléments du dossier</h3>
            </div>

            <span class="shinobimancer-status-pill">Éditable</span>
          </div>

          <div class="shinobimancer-identity-grid">
            <button type="button" class="shinobimancer-portrait-card shinobimancer-portrait-picker">
              <img src="{{actorImg}}" alt="{{actorName}}" />
              <span class="shinobimancer-mini-note">Cliquer pour choisir le portrait</span>
            </button>

            <div class="shinobimancer-form-preview shinobimancer-form-preview-large">
              <label>
                Nom du ninja
                <input type="text" value="{{identity.name}}" data-shinobimancer-field="name" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Surnom Shinobi
                <input type="text" value="{{identity.prenom}}" data-shinobimancer-field="system.identity.prenom" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Âge
                <input type="text" value="{{identity.age}}" data-shinobimancer-field="system.identity.age" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Naissance
                <input type="text" value="{{identity.birth}}" data-shinobimancer-field="system.identity.birth" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Sexe
                <input type="text" value="{{identity.sex}}" data-shinobimancer-field="system.identity.sex" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Rang de départ
                <input type="text" value="{{identity.rank}}" readonly />
              </label>

              <label>
                Taille
                <input type="text" value="{{identity.height}}" data-shinobimancer-field="system.identity.height" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Poids
                <input type="text" value="{{identity.weight}}" data-shinobimancer-field="system.identity.weight" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Cheveux
                <input type="text" value="{{identity.hair}}" data-shinobimancer-field="system.identity.hair" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Yeux
                <input type="text" value="{{identity.eyes}}" data-shinobimancer-field="system.identity.eyes" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Sensei
                <input type="text" value="{{identity.sensei}}" data-shinobimancer-field="system.identity.sensei" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Équipe
                <input type="text" value="{{identity.team}}" data-shinobimancer-field="system.identity.team" placeholder="À renseigner" {{#if creationLocked}}disabled{{/if}} />
              </label>

              <label>
                Type de Nindō
                <select data-shinobimancer-field="system.nindo.choiceMode" {{#if creationLocked}}disabled{{/if}}>
                  {{#each nindoChoiceModes as |mode|}}
                    <option value="{{mode.key}}" {{#if mode.selected}}selected{{/if}}>
                      {{mode.label}}
                    </option>
                  {{/each}}
                </select>
              </label>

              <label>
                Nindō prédéfini
                <select data-shinobimancer-field="system.nindo.preset" {{#if creationLocked}}disabled{{/if}}>
                  <option value="">— Aucun —</option>
                  {{#each nindoPresets as |preset|}}
                    <option value="{{preset.key}}" {{#if preset.selected}}selected{{/if}}>
                      {{preset.label}}
                    </option>
                  {{/each}}
                </select>
              </label>

              {{#if selectedNindoPreset}}
                <div class="shinobimancer-nindo-description is-wide">
                  <strong>{{selectedNindoPreset.name}}</strong>
                  <p>{{selectedNindoPreset.description}}</p>
                </div>
              {{/if}}

              <label class="is-wide">
                Nindō / devise personnelle
                <textarea data-shinobimancer-field="system.identity.nindoText" placeholder="Formule, promesse ou voie personnelle du Shinobi." {{#if creationLocked}}disabled{{/if}}>{{identity.nindo}}</textarea>
              </label>

              <label class="is-wide">
                Notes de création
                <textarea data-shinobimancer-field="system.progression.creation.notes" placeholder="Notes rapides pour le dossier de création." {{#if creationLocked}}disabled{{/if}}>{{identity.notes}}</textarea>
              </label>
            </div>
          </div>

          <div class="shinobimancer-notice-list">
            {{#each previewNotices as |notice|}}
              <div class="shinobimancer-notice is-{{notice.type}}">
                <strong>{{notice.title}}</strong>
                <span>{{notice.text}}</span>
              </div>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if (eq currentStep "village")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Registre du village</p>
              <h3>Choix du village d’origine</h3>
            </div>

            <span class="shinobimancer-status-pill">Prévisualisation</span>
          </div>

          <div class="shinobimancer-card-grid">
            {{#each villageCards as |village|}}
              <article
                class="shinobimancer-data-card shinobimancer-village-card {{#if village.selected}}is-selected{{/if}} {{#unless village.selectable}}is-disabled{{/unless}}"
                data-village="{{village.key}}"
              >
                <div class="shinobimancer-card-emblem">
                  {{#if village.selectable}}
                    <i class="fa-solid fa-leaf"></i>
                  {{else}}
                    <i class="fa-solid fa-lock"></i>
                  {{/if}}
                </div>

                <div>
                  <p class="shinobimancer-card-eyebrow">{{village.status}}</p>
                  <h4>{{village.label}}</h4>
                  <p>{{village.description}}</p>
                </div>
              </article>
            {{/each}}
          </div>

          <div class="shinobimancer-notice is-info">
            <strong>Note de maquette</strong>
            <span>Konoha reste le village disponible pour la phase de test. Les autres villages sont affichés pour préparer l’extension future.</span>
          </div>
        </section>
      {{/if}}

      {{#if (eq currentStep "heritage")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Origine shinobi</p>
              <h3>Type d’héritage</h3>
            </div>

            <span class="shinobimancer-status-pill">Choix fondateur</span>
          </div>

          <div class="shinobimancer-card-grid is-two-columns">
            {{#each heritageModeCards as |mode|}}
              <article
                class="shinobimancer-data-card shinobimancer-heritage-card {{#if mode.selected}}is-selected{{/if}} {{#unless mode.available}}is-disabled{{/unless}}"
                data-heritage-mode="{{mode.key}}"
                data-available="{{#if mode.available}}true{{else}}false{{/if}}"
              >
                <div class="shinobimancer-card-emblem">
                  <i class="fa-solid fa-scroll"></i>
                </div>

                <div>
                  <p class="shinobimancer-card-eyebrow">{{#if mode.available}}Disponible{{else}}Verrouillé{{/if}}</p>
                  <h4>{{mode.label}}</h4>
                  <p>{{mode.description}}</p>
                  <span class="shinobimancer-mini-note">{{mode.note}}</span>
                </div>
              </article>
            {{/each}}
          </div>

          <div class="shinobimancer-notice is-warning">
            <strong>Validation MJ</strong>
            <span>Les modes hybrides et le clan caché restent soumis aux options MJ. Le Réel Clan porte les obligations mécaniques quand le mode Clan caché est utilisé.</span>
          </div>
        </section>
      {{/if}}

      {{#if (eq currentStep "clan")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Registre des clans</p>
              <h3>Clans jouables du Shinobimancer</h3>
            </div>

            <span class="shinobimancer-status-pill">25 clans jouables</span>
          </div>

          {{#if hiddenClanMode}}
            <div class="shinobimancer-notice is-warning">
              <strong>Clan caché / dissimulé</strong>
              <span>Choisis d’abord le clan officiel visible socialement, puis le Réel Clan qui portera la mécanique de Lignée.</span>
            </div>

            <section class="shinobimancer-panel">
              <div class="shinobimancer-panel-heading">
                <div>
                  <p class="shinobimancer-kicker">Identité sociale</p>
                  <h3>Clan officiel / social</h3>
                </div>
              </div>

              <div class="shinobimancer-clan-grid">
                {{#each hiddenClanOfficialCards as |clan|}}
                  <article
                    class="shinobimancer-clan-card shinobimancer-hidden-clan-card {{#if clan.selected}}is-selected{{/if}}"
                    data-clan="{{clan.key}}"
                    data-hidden-clan-role="officialClan"
                  >
                    <div class="shinobimancer-clan-emblem">
                      <img src="{{clan.kamon}}" alt="{{clan.label}}" />
                    </div>

                    <div class="shinobimancer-clan-body">
                      <p class="shinobimancer-card-eyebrow">{{clan.village}} · couverture sociale</p>
                      <h4>{{clan.label}}</h4>
                      <p>{{clan.tagline}}</p>

                      <div class="shinobimancer-clan-feature">
                        Ce clan est affiché publiquement, mais n’accorde aucune mécanique de Lignée par défaut.
                      </div>

                      {{#if clan.selected}}
                        <span class="shinobimancer-selected-stamp">Clan officiel</span>
                      {{/if}}
                    </div>
                  </article>
                {{/each}}
              </div>
            </section>

            <section class="shinobimancer-panel">
              <div class="shinobimancer-panel-heading">
                <div>
                  <p class="shinobimancer-kicker">Héritage réel</p>
                  <h3>Réel Clan</h3>
                </div>
              </div>

              <div class="shinobimancer-clan-grid">
                {{#each hiddenClanRealCards as |clan|}}
                  <article
                    class="shinobimancer-clan-card shinobimancer-hidden-clan-card {{#if clan.selected}}is-selected{{/if}}"
                    data-clan="{{clan.key}}"
                    data-hidden-clan-role="realClan"
                  >
                    <div class="shinobimancer-clan-emblem">
                      <img src="{{clan.kamon}}" alt="{{clan.label}}" />
                    </div>

                    <div class="shinobimancer-clan-body">
                      <p class="shinobimancer-card-eyebrow">{{clan.village}} · vraie lignée</p>
                      <h4>{{clan.label}}</h4>
                      <p>{{clan.tagline}}</p>

                      <div class="shinobimancer-clan-feature">
                        Ce clan reçoit la Base Lignée et les pouvoirs mécaniques, selon l’état narratif choisi.
                      </div>

                      {{#if clan.selected}}
                        <span class="shinobimancer-selected-stamp">Réel Clan</span>
                      {{/if}}
                    </div>
                  </article>
                {{/each}}
              </div>
            </section>

            <section class="shinobimancer-panel">
              <div class="shinobimancer-panel-heading">
                <div>
                  <p class="shinobimancer-kicker">Éveil narratif</p>
                  <h3>État de connaissance de la vraie lignée</h3>
                </div>
              </div>

              <label>
                État de connaissance
                <select class="shinobimancer-hidden-clan-awareness" {{#if creationLocked}}disabled{{/if}}>
                  {{#each hiddenClanAwarenessStates as |state|}}
                    <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                      {{state.label}}
                    </option>
                  {{/each}}
                </select>
              </label>

              <div class="shinobimancer-notice is-info">
                <strong>{{hiddenClanSummary.awarenessLabel}}</strong>
                <span>{{hiddenClanSummary.awarenessSummary}}</span>
              </div>
            </section>
          {{else}}
          <div class="shinobimancer-clan-grid">
            {{#each clanCards as |clan|}}
              <article class="shinobimancer-clan-card {{#if clan.selected}}is-selected{{/if}}" data-clan="{{clan.key}}">
                <div class="shinobimancer-clan-emblem">
                  <img src="{{clan.kamon}}" alt="{{clan.label}}" />
                </div>

                <div class="shinobimancer-clan-body">
                  <p class="shinobimancer-card-eyebrow">{{clan.village}} · {{clan.skillLabel}}</p>
                  <h4>{{clan.label}}</h4>
                  <p>{{clan.tagline}}</p>

                  <div class="shinobimancer-clan-feature">
                    {{clan.feature}}
                  </div>

                  <div class="shinobimancer-notice is-warning">
                    <strong>Avertissement</strong>
                    <span>{{clan.warning}}</span>
                  </div>
                </div>
              </article>
            {{/each}}
          </div>

          <div class="shinobimancer-notice is-info">
            <strong>Clans étendus</strong>
            <span>Les 25 clans jouables déclarés dans le système sont maintenant proposés à la création. Les effets complexes restent automatisés plus tard par les chantiers Inventaire, Combat, Techniques et Santé.</span>
          </div>
          {{/if}}
        </section>
      {{/if}}

      {{#if (eq currentStep "bases")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Structure du Shinobi</p>
              <h3>Bases / XP</h3>
            </div>

            <span class="shinobimancer-status-pill">Échelle 1–14</span>
          </div>

          <div class="shinobimancer-bases-layout">
            <div class="shinobimancer-radar-card">
              <div class="shinobimancer-radar-frame">
                {{{baseRadarSvg}}}
              </div>

              <div class="shinobimancer-radar-caption">
                <strong>Toile des Bases</strong>
                <span>Profil visuel généré depuis les 7 Bases du personnage.</span>
              </div>
            </div>

            <div class="shinobimancer-base-list">
              {{#each baseRows as |base|}}
                <div class="shinobimancer-base-row">
                  <div>
                    <strong>{{base.label}}</strong>
                    <span>{{base.key}} · naturel {{base.value}} · coût suivant : {{base.nextCostLabel}}</span>
                  </div>

                  <div class="shinobimancer-base-meter">
                    <span style="width: {{base.percent}}%;"></span>
                  </div>

                  <div class="shinobimancer-base-score">
                    <button
                      type="button"
                      class="shinobimancer-base-decrease"
                      data-base="{{base.key}}"
                      {{#if ../creationLocked}}disabled{{/if}}
                    >
                      −
                    </button>

                    <strong>{{base.total}} / {{base.max}}</strong>

                    <button
                      type="button"
                      class="shinobimancer-base-increase"
                      data-base="{{base.key}}"
                      {{#if ../creationLocked}}disabled{{/if}}
                    >
                      +
                    </button>
                  </div>

                  {{#if base.hasHiddenEffectiveValue}}
                    <div class="shinobimancer-notice is-warning">
                      <strong>Lignée effective verrouillée</strong>
                      <span>
                        Lignée effective : {{base.effectiveLineage}} malgré une Base brute de {{base.value}}.
                      </span>
                    </div>
                  {{/if}}
                </div>
              {{/each}}
            </div>
          </div>

          <div class="shinobimancer-xp-strip">
            <div>
              <span>XP total</span>
              <strong>{{experienceSummary.total}}</strong>
            </div>

            <div>
              <span>XP dépensé</span>
              <strong>{{experienceSummary.spent}}</strong>
            </div>

            <div>
              <span>XP disponible</span>
              <strong>{{experienceSummary.available}}</strong>
            </div>

            <div>
              <span>Plafond actuel</span>
              <strong>{{baseCap}}</strong>
            </div>
          </div>

          <div class="shinobimancer-notice is-info">
            <strong>Ordre de création</strong>
            <span>Les Bases passent avant les affinités et compétences, car elles structurent les plafonds mécaniques du personnage.</span>
          </div>
        </section>
      {{/if}}

      {{#if (eq currentStep "affinities")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Chakra</p>
              <h3>Affinités naturelles et spécialisations</h3>
            </div>

            <span class="shinobimancer-status-pill">Après les Bases</span>
          </div>

          <div class="shinobimancer-affinity-grid">
            {{#each affinityCards as |affinity|}}
              <article
                class="shinobimancer-affinity-card {{#if affinity.isSelected}}is-selected{{/if}} {{#if affinity.isSecondary}}is-secondary{{/if}} {{#if affinity.isForced}}is-forced{{/if}} {{#if affinity.disabled}}is-disabled{{/if}}"
                data-affinity="{{affinity.key}}"
              >
                <div class="shinobimancer-affinity-icon">{{affinity.icon}}</div>

                <div>
                  <p class="shinobimancer-card-eyebrow">{{affinity.status}}</p>
                  <h4>{{affinity.label}}</h4>
                  <p>{{affinity.description}}</p>

                  {{#if affinity.playstyle}}
                    <p class="shinobimancer-mini-note">{{affinity.playstyle}}</p>
                  {{/if}}

                  {{#if affinity.strengths.length}}
                    <div class="shinobimancer-tag-row">
                      {{#each affinity.strengths as |strength|}}
                        <span>{{strength}}</span>
                      {{/each}}
                    </div>
                  {{else}}
                    {{#if affinity.previewTags.length}}
                      <div class="shinobimancer-tag-row">
                        {{#each affinity.previewTags as |tag|}}
                          <span>{{tag}}</span>
                        {{/each}}
                      </div>
                    {{/if}}
                  {{/if}}

                  <span>{{affinity.tone}}</span>
                </div>
              </article>
            {{/each}}
          </div>

          <div class="shinobimancer-notice is-warning">
            <strong>Rappel</strong>
            <span>La première affinité libre sélectionnée devient Principale. La seconde devient Secondaire. Les affinités imposées par clan sont verrouillées.</span>
          </div>

          <section class="shinobimancer-panel">
            <div class="shinobimancer-panel-heading">
              <div>
                <p class="shinobimancer-kicker">Chakra passif</p>
                <h3>Spécialisations de Chakra</h3>
              </div>

              <span class="shinobimancer-status-pill">
                {{chakraSpecializationState.spent}} / {{chakraSpecializationState.available}}
              </span>
            </div>

            <div class="shinobimancer-skill-summary">
              <div>
                <span>Choix dépensés</span>
                <strong>{{chakraSpecializationState.spent}}</strong>
              </div>

              <div>
                <span>Maximum</span>
                <strong>{{chakraSpecializationState.available}}</strong>
              </div>

              <div>
                <span>Restants</span>
                <strong>{{chakraSpecializationState.remaining}}</strong>
              </div>
            </div>

            <div class="shinobimancer-skill-list">
              {{#each chakraSpecializations as |spec|}}
                <article class="shinobimancer-skill-pill {{#if spec.value}}is-owned{{/if}}">
                  <div>
                    <strong>{{spec.label}}</strong>
                    <span>{{spec.effect}}</span>
                  </div>

                  <div class="shinobimancer-base-score">
                    <button
                      type="button"
                      class="shinobimancer-chakra-specialization-decrease"
                      data-specialization="{{spec.key}}"
                      {{#unless spec.canDecrease}}disabled{{/unless}}
                    >
                      −
                    </button>

                    <b>{{spec.value}}</b>

                    <button
                      type="button"
                      class="shinobimancer-chakra-specialization-increase"
                      data-specialization="{{spec.key}}"
                      {{#unless spec.canIncrease}}disabled{{/unless}}
                    >
                      +
                    </button>
                  </div>
                </article>
              {{/each}}
            </div>

            {{#if chakraSpecializationState.overLimit}}
              <div class="shinobimancer-notice is-error">
                <strong>Trop de spécialisations</strong>
                <span>Le personnage possède plus de spécialisations que son rang actuel ne le permet.</span>
              </div>
            {{/if}}
            {{#if chakraSpecializationState.remaining}}
              <div class="shinobimancer-notice is-warning">
                <strong>Spécialisation requise</strong>
                <span>Choisis ta spécialisation de Chakra de départ avant de valider le dossier.</span>
              </div>
            {{/if}}
          </section>
        </section>
      {{/if}}

      {{#if (eq currentStep "skills")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Formation initiale</p>
              <h3>Compétences</h3>
            </div>

            <span class="shinobimancer-status-pill">
              {{summaryPanel.initialSkillsUsed}} / {{summaryPanel.maxInitialSkills}}
            </span>
          </div>

          <div class="shinobimancer-skill-summary">
            <div>
              <span>Utilisées</span>
              <strong>{{summaryPanel.initialSkillsUsed}}</strong>
            </div>

            <div>
              <span>Maximum</span>
              <strong>{{summaryPanel.maxInitialSkills}}</strong>
            </div>

            <div>
              <span>Restantes</span>
              <strong>{{summaryPanel.initialSkillsRemaining}}</strong>
            </div>
          </div>

          <div class="shinobimancer-skill-groups">
            {{#each skillGroups as |group|}}
              <section class="shinobimancer-skill-group">
                <h4>{{group.label}}</h4>

                <div class="shinobimancer-skill-list">
                  {{#each group.skills as |skill|}}
                    <article
                      class="shinobimancer-skill-pill {{#if skill.owned}}is-owned{{/if}} {{#if skill.manualOwned}}is-selected{{/if}} {{#if skill.lockedBySource}}is-locked{{/if}} {{#if skill.selectableAsInitial}}is-selectable{{/if}}"
                      data-skill="{{skill.key}}"
                    >
                      <div>
                        <strong>{{skill.label}}</strong>
                        <span>{{skill.baseLabel}} · {{skill.sourceText}} · coût suivant : {{skill.nextCostLabel}}</span>
                      </div>

                      <div class="shinobimancer-base-score">
                        <button
                          type="button"
                          class="shinobimancer-skill-decrease"
                          data-skill="{{skill.key}}"
                          {{#unless skill.canDecrease}}disabled{{/unless}}
                        >
                          −
                        </button>

                        <b>{{skill.total}}</b>

                        <button
                          type="button"
                          class="shinobimancer-skill-increase"
                          data-skill="{{skill.key}}"
                          {{#unless skill.canIncrease}}disabled{{/unless}}
                        >
                          +
                        </button>
                      </div>
                    </article>
                  {{/each}}
                </div>
              </section>
            {{/each}}
          </div>
        </section>
      {{/if}}

      {{#if (eq currentStep "equipment")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Armurerie de départ</p>
              <h3>Paquetage ninja</h3>
            </div>

            <span class="shinobimancer-status-pill">Choix requis</span>
          </div>

          <div class="shinobimancer-notice is-info">
            <strong>Règle du paquetage</strong>
            <span>Choisissez 1 arme principale, puis exactement 2 lots d’armes de jet ou consommables ninja. Les pilules et kits sont accordés automatiquement.</span>
          </div>

          <section class="shinobimancer-panel">
            <div class="shinobimancer-panel-heading">
              <div>
                <p class="shinobimancer-kicker">Choix 1 / 1</p>
                <h3>Arme principale</h3>
              </div>
            </div>

            <div class="shinobimancer-equipment-grid">
              {{#each equipmentPreview.mainWeapons as |item|}}
                <article
                  class="shinobimancer-equipment-card shinobimancer-equipment-main {{#if item.selected}}is-selected{{/if}}"
                  data-equipment="{{item.key}}"
                >
                  <div class="shinobimancer-equipment-quantity">{{item.quantityLabel}}</div>

                  <div>
                    <p class="shinobimancer-card-eyebrow">{{item.type}}</p>
                    <h4>{{item.name}}</h4>
                    <p>{{item.description}}</p>
                    {{#if item.selected}}
                      <span class="shinobimancer-selected-stamp">Sélectionné</span>
                    {{/if}}
                  </div>
                </article>
              {{/each}}
            </div>
          </section>

          <section class="shinobimancer-panel">
            <div class="shinobimancer-panel-heading">
              <div>
                <p class="shinobimancer-kicker">Choix {{equipmentPreview.selectedCombatLotCount}} / {{equipmentPreview.requiredCombatLotCount}}</p>
                <h3>Lots de combat</h3>
              </div>
            </div>

            <div class="shinobimancer-equipment-grid">
              {{#each equipmentPreview.combatLots as |item|}}
                <article
                  class="shinobimancer-equipment-card shinobimancer-equipment-lot {{#if item.selected}}is-selected{{/if}}"
                  data-equipment="{{item.key}}"
                >
                  <div class="shinobimancer-equipment-quantity">{{item.quantityLabel}}</div>

                  <div>
                    <p class="shinobimancer-card-eyebrow">{{item.type}}</p>
                    <h4>{{item.name}}</h4>
                    <p>{{item.description}}</p>
                    {{#if item.selected}}
                      <span class="shinobimancer-selected-stamp">Sélectionné</span>
                    {{/if}}
                  </div>
                </article>
              {{/each}}
            </div>
          </section>

          <section class="shinobimancer-panel">
            <div class="shinobimancer-panel-heading">
              <div>
                <p class="shinobimancer-kicker">Accordé automatiquement</p>
                <h3>Pilules et kits</h3>
              </div>
            </div>

            <div class="shinobimancer-equipment-grid">
              {{#each equipmentPreview.fixed as |item|}}
                <article class="shinobimancer-equipment-card is-fixed">
                  <div class="shinobimancer-equipment-quantity">{{item.quantityLabel}}</div>

                  <div>
                    <p class="shinobimancer-card-eyebrow">{{item.type}}</p>
                    <h4>{{item.name}}</h4>
                    <p>{{item.description}}</p>
                  </div>
                </article>
              {{/each}}
            </div>
          </section>

          <div class="shinobimancer-notice is-info">
            <strong>Attribution finale</strong>
            <span>Le paquetage sera créé dans l’inventaire au moment de la validation finale du dossier.</span>
          </div>
        </section>
      {{/if}}

      {{#if (eq currentStep "summary")}}
        <section class="shinobimancer-panel">
          <div class="shinobimancer-panel-heading">
            <div>
              <p class="shinobimancer-kicker">Contrôle final</p>
              <h3>Résumé du dossier</h3>
            </div>

            <span class="shinobimancer-status-pill">Validation du dossier</span>
          </div>

          <div class="shinobimancer-final-sheet">
            <section class="shinobimancer-final-identity">
              <div class="shinobimancer-final-portrait">
                <img src="{{actorImg}}" alt="{{actorName}}" />
              </div>

              <div class="shinobimancer-final-fields">
                <h4>{{actorName}}</h4>

                <dl>
                  <div>
                    <dt>Village</dt>
                    <dd>{{summaryPanel.village}}</dd>
                  </div>

                  <div>
                    <dt>Statut</dt>
                    <dd>{{summaryPanel.status}}</dd>
                  </div>

                  <div>
                    <dt>Héritage</dt>
                    <dd>{{summaryPanel.heritage}}</dd>
                  </div>

                  <div>
                    <dt>Rang</dt>
                    <dd>{{identity.rank}}</dd>
                  </div>

                  <div>
                    <dt>Sensei</dt>
                    <dd>{{identity.sensei}}</dd>
                  </div>

                  <div>
                    <dt>Équipe</dt>
                    <dd>{{identity.team}}</dd>
                  </div>
                </dl>
              </div>

              <div class="shinobimancer-final-radar">
                {{{baseRadarSvg}}}
              </div>
            </section>

            <section class="shinobimancer-final-blocks">
              <article>
                <h4>Affinités</h4>
                <div class="shinobimancer-affinity-tags">
                  <div>
                    {{#each summaryPanel.affinities as |affinity|}}
                      <span>{{affinity}}</span>
                    {{/each}}
                  </div>
                </div>
              </article>

              <article>
                <h4>Compétences</h4>
                <p>{{summaryPanel.initialSkillsUsed}} / {{summaryPanel.maxInitialSkills}} utilisées — {{summaryPanel.initialSkillsRemaining}} restante(s).</p>
              </article>

              <article>
                <h4>XP</h4>
                <p>{{summaryPanel.xpAvailable}} XP disponible(s).</p>
              </article>

              <article>
                <h4>Équipement</h4>
                <p>
                  Arme principale : {{equipmentPreview.selectedMainWeapon}}.
                  Lots de combat sélectionnés : {{equipmentPreview.selectedCombatLotCount}} / {{equipmentPreview.requiredCombatLotCount}}.
                  Les pilules et kits seront accordés automatiquement.
                </p>
              </article>
            </section>

            <section class="shinobimancer-final-alerts">
              {{#if creationValidation.errors}}
                <div class="shinobimancer-notice is-error">
                  <strong>Erreurs bloquantes</strong>
                  <ul>
                    {{#each creationValidation.errors as |error|}}
                      <li>{{error}}</li>
                    {{/each}}
                  </ul>
                </div>
              {{/if}}

              {{#if creationValidation.warnings}}
                <div class="shinobimancer-notice is-warning">
                  <strong>Avertissements</strong>
                  <ul>
                    {{#each creationValidation.warnings as |warning|}}
                      <li>{{warning}}</li>
                    {{/each}}
                  </ul>
                </div>
              {{/if}}

              {{#if summaryPanel.valid}}
                <div class="shinobimancer-notice is-success">
                  <strong>Dossier conforme</strong>
                  <span>Aucune erreur bloquante détectée. Le dossier peut être validé par le joueur.</span>
                </div>
              {{/if}}
            </section>

            {{#if creationLocked}}
              <div class="shinobimancer-notice is-success">
                <strong>Dossier déjà validé</strong>
                <span>Le sceau officiel est apposé. La création est verrouillée.</span>
              </div>
            {{else}}
              <button
                type="button"
                class="shinobimancer-button is-primary shinobimancer-finalize-creation"
                {{#unless canFinalizeCreation}}disabled{{/unless}}
              >
                <i class="fa-solid fa-stamp"></i>
                Valider mon dossier de Shinobi
              </button>
            {{/if}}
          </div>
        </section>
      {{/if}}
    </main>

    <aside class="shinobimancer-summary">
      <div class="shinobimancer-summary-header">
        <p class="shinobimancer-kicker">Résumé permanent</p>
        <h3>Dossier actuel</h3>
      </div>

      <div class="shinobimancer-summary-portrait">
        <img src="{{actorImg}}" alt="{{actorName}}" />
        <strong>{{actorName}}</strong>
      </div>

      <dl class="shinobimancer-summary-list">
        <div>
          <dt>Village</dt>
          <dd>{{summaryPanel.village}}</dd>
        </div>

        <div>
          <dt>Statut</dt>
          <dd>{{summaryPanel.status}}</dd>
        </div>

        <div>
          <dt>Héritage</dt>
          <dd>{{summaryPanel.heritage}}</dd>
        </div>

        <div>
          <dt>Type</dt>
          <dd>{{summaryPanel.heritageMode}}</dd>
        </div>

        <div>
          <dt>Compétences</dt>
          <dd>
            {{summaryPanel.initialSkillsUsed}} / {{summaryPanel.maxInitialSkills}}
            — restantes : {{summaryPanel.initialSkillsRemaining}}
          </dd>
        </div>

        <div>
          <dt>XP disponible</dt>
          <dd>{{summaryPanel.xpAvailable}}</dd>
        </div>
      </dl>

      <div class="shinobimancer-affinity-tags">
        <strong>Affinités</strong>
        <div>
          {{#each summaryPanel.affinities as |affinity|}}
            <span>{{affinity}}</span>
          {{/each}}
        </div>
      </div>

      <div class="shinobimancer-validation-state {{#if summaryPanel.valid}}is-valid{{else}}is-invalid{{/if}}">
        {{#if summaryPanel.valid}}
          <strong>Dossier conforme</strong>
          <span>Aucune erreur bloquante détectée.</span>
        {{else}}
          <strong>Dossier à compléter</strong>
          <span>
            {{summaryPanel.errorCount}} erreur(s),
            {{summaryPanel.warningCount}} avertissement(s).
          </span>
        {{/if}}
      </div>
            {{#if creationValidation.errors.length}}
        <div class="shinobimancer-notice is-error">
          <strong>À corriger</strong>
          <ul>
            {{#each creationValidation.errors as |error|}}
              <li>{{error}}</li>
            {{/each}}
          </ul>
        </div>
      {{/if}}

      {{#if creationValidation.warnings.length}}
        <div class="shinobimancer-notice is-warning">
          <strong>À surveiller</strong>
          <ul>
            {{#each creationValidation.warnings as |warning|}}
              <li>{{warning}}</li>
            {{/each}}
          </ul>
        </div>
      {{/if}}
    </aside>
  </div>

  <footer class="shinobimancer-footer">
    <button type="button" class="shinobimancer-button is-secondary shinobimancer-previous-step" {{#unless canGoPrevious}}disabled{{/unless}}>
      <i class="fa-solid fa-arrow-left"></i>
      Retour
    </button>

    <div class="shinobimancer-footer-note">
      Étape {{activeStep.number}} / 9 — {{activeStep.label}}
    </div>

    <div class="shinobimancer-footer-actions">
      <button type="button" class="shinobimancer-button is-secondary shinobimancer-close">
        Fermer
      </button>

      <button type="button" class="shinobimancer-button is-primary shinobimancer-next-step" {{#unless canGoNext}}disabled{{/unless}}>
        Suivant
        <i class="fa-solid fa-arrow-right"></i>
      </button>
    </div>
  </footer>
</section>