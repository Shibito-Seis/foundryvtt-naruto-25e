                        L’œil gauche se débloque après confirmation PJ de l’œil droit.
                      </div>
                    {{/if}}

                    <label>
                      Pouvoir
                      <select
                        class="uchiha-eye-power-choice"
                        data-eye="left"
                        {{#unless v2.lineage.mangekyo.canEditLeftEye}}disabled{{/unless}}
                      >
                        <option value="">— Aucun —</option>
                        {{#each v2.lineage.mangekyo.leftEyePowerOptions as |power|}}
                          <option value="{{power.key}}" {{#if power.selected}}selected{{/if}} {{#if power.disabled}}disabled{{/if}}>
                            {{power.label}}
                          </option>
                        {{/each}}
                      </select>
                    </label>

                    <div class="shinobi-v2-data-grid">
                      <div><strong>Pouvoir actuel</strong><span>{{v2.lineage.mangekyo.leftEyePowerLabel}}</span></div>
                      <div><strong>État</strong><span>{{v2.lineage.mangekyo.leftEyeStateLabel}}</span></div>
                      <div><strong>PJ</strong><span>{{#if v2.lineage.mangekyo.leftEyePlayerValidated}}Validé{{else}}À confirmer{{/if}}</span></div>
                      <div><strong>MJ</strong><span>{{#if v2.lineage.mangekyo.leftEyeGmValidated}}Validé{{else}}À valider{{/if}}</span></div>
                    </div>

                    {{#unless v2.lineage.mangekyo.leftEyeValidation.valid}}
                      <div class="shinobi-v2-warning">{{v2.lineage.mangekyo.leftEyeValidation.reason}}</div>
                    {{/unless}}

                    <div class="shinobi-v2-button-row">
                      <button
                        type="button"
                        class="uchiha-eye-player-validate"
                        data-eye="left"
                        {{#unless v2.lineage.mangekyo.canValidateLeftEyeAsPlayer}}disabled{{/unless}}
                      >
                        Confirmer PJ
                      </button>

                      {{#if isGM}}
                        <button type="button" class="uchiha-eye-reset" data-eye="left">
                          MJ : annuler
                        </button>
                      {{/if}}
                    </div>

                    {{#if isGM}}
                      <label>
                        Validation MJ
                        <input
                          type="checkbox"
                          class="uchiha-eye-gm-validate"
                          data-eye="left"
                          {{#if v2.lineage.mangekyo.leftEyeGmValidated}}checked{{/if}}
                          {{#unless v2.lineage.mangekyo.leftEyePlayerValidated}}disabled{{/unless}}
                        />
                      </label>

                      <label>
                        État de l’œil
                        <select class="uchiha-eye-state" data-eye="left">
                          {{#each v2.lineage.mangekyo.leftEyeStateOptions as |state|}}
                            <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                              {{state.label}}
                            </option>
                          {{/each}}
                        </select>
                      </label>
                    {{/if}}
                  </article>
                </div>
              </section>
            {{/if}}
          </section>

          <section class="shinobi-v2-panel">
            <h2>Pouvoirs de lignée</h2>

            {{#if v2.lineage.hasPowers}}
              <div class="shinobi-v2-card-list">
                {{#each v2.lineage.powers as |power|}}
                  <article class="shinobi-v2-item-card {{#if power.active}}is-active{{/if}}">
                    <div>
                      <strong>{{power.name}}</strong>
                      <span>{{power.typeLabel}}</span>
                      <small>
                        Activation {{power.activationCost}}
                        {{#if power.maintenanceCost}}
                          · Entretien {{power.maintenanceCost}}
                        {{/if}}
                      </small>
                      {{#if power.effect}}
                        <small>{{power.effect}}</small>
                      {{/if}}
                    </div>

                    <div class="shinobi-v2-button-column">
                      {{#if power.isActivable}}
                        <button
                          type="button"
                          class="lineage-power-toggle"
                          data-item-id="{{power.id}}"
                        >
                          {{#if power.active}}Désactiver{{else}}Activer{{/if}}
                        </button>
                      {{/if}}
                    </div>
                  </article>
                {{/each}}
              </div>
            {{else}}
              <p class="shinobi-v2-muted">Aucun pouvoir de lignée sur cette fiche.</p>
            {{/if}}
          </section>

          <section class="shinobi-v2-panel">
            <h2>Progression de lignée</h2>

            {{#if v2.lineage.hasTracks}}
              {{#each v2.lineage.tracks as |track|}}
                <section class="shinobi-v2-lineage-track">
                  <h3>{{track.role}} — {{track.label}}</h3>

                  {{#if track.note}}
                    <p class="shinobi-v2-muted">{{track.note}}</p>
                  {{/if}}

                  <div class="shinobi-v2-lineage-ranks">
                    {{#each track.ranks as |rank|}}
                      <article class="shinobi-v2-lineage-rank {{#if rank.unlocked}}is-unlocked{{else}}is-locked{{/if}} {{#if rank.narrativeLocked}}is-narrative-locked{{/if}} {{#if rank.current}}is-current{{/if}}">
                        <header>
                          <strong>Rang {{rank.rank}}</strong>
                          <span>{{#if rank.unlocked}}Déverrouillé{{else}}Verrouillé{{/if}}</span>
                        </header>

                        {{#if rank.narrativeLocked}}
                          <div class="shinobi-v2-warning">{{rank.lockReason}}</div>
                        {{/if}}

                        {{#if rank.hasFeatures}}
                          {{#each rank.features as |feature|}}
                            <div class="shinobi-v2-lineage-feature">
                              <strong>{{feature.label}}{{#unless feature.label}}{{feature.title}}{{/unless}}</strong>

                              {{#if feature.type}}
                                <span>{{feature.type}}</span>
                              {{/if}}

                              {{#if feature.summary}}
                                <p>{{feature.summary}}</p>
                              {{/if}}

                              {{#if feature.description}}
                                <p>{{feature.description}}</p>
                              {{/if}}

                              {{#if feature.mechanical}}
                                <p><strong>Effet :</strong> {{feature.mechanical}}</p>
                              {{/if}}
                            </div>
                          {{/each}}
                        {{else}}
                          <p class="shinobi-v2-muted">{{rank.placeholder}}</p>
                        {{/if}}
                      </article>
                    {{/each}}
                  </div>
                </section>
              {{/each}}
            {{else}}
              <p class="shinobi-v2-muted">Aucune piste de lignée disponible.</p>
            {{/if}}
          </section>

          <section class="shinobi-v2-panel">
            <h2>Greffes / implants</h2>

            <p class="shinobi-v2-muted">
              Emplacement préparé pour les greffes futures : Sharingan, Byakugan, Rinnegan, cellules Senju et autres implants narratifs.
            </p>
          </section>

        </div>
      {{/if}}
    </div>

    <div class="tab" data-group="primary" data-tab="progression">
      <div class="shinobi-v2-grid">

        <section class="shinobi-v2-panel">
          <h2>Rang</h2>

          <div class="shinobi-v2-data-grid">
            <div><strong>Rang actuel</strong><span>{{v2.progression.rank.currentLabel}}</span></div>
            <div><strong>Plafond de Bases</strong><span>{{v2.progression.rank.currentBaseCap}}</span></div>

            {{#if v2.progression.rank.next}}
              <div><strong>Prochain rang</strong><span>{{v2.progression.rank.next.label}}</span></div>
              <div><strong>XP requise</strong><span>{{v2.progression.rank.next.xp}}</span></div>
            {{else}}
              <div><strong>Prochain rang</strong><span>Rang maximal atteint</span></div>
            {{/if}}
          </div>

          {{#if v2.progression.rank.next}}
            <div class="shinobi-v2-rank-checks">
              <h3>Conditions de promotion</h3>

              {{#each v2.progression.rank.checks as |check|}}
                <div class="shinobi-v2-rank-check {{#if check.passed}}is-passed{{else}}is-failed{{/if}}">
                  <span>{{#if check.passed}}✓{{else}}✗{{/if}}</span>

                  <div>
                    <strong>{{check.label}}</strong>
                    <small>{{check.detail}}</small>
                  </div>
                </div>
              {{/each}}
            </div>

            {{#if isGM}}
              <div class="shinobi-v2-button-row">
                <button type="button" class="rank-promote" {{#unless v2.progression.rank.canPromote}}disabled{{/unless}}>
                  Valider le passage au rang suivant
                </button>
              </div>
            {{else}}
              <p class="shinobi-v2-muted">Seul le MJ peut valider un passage de rang.</p>
            {{/if}}
          {{else}}
            <p class="shinobi-v2-muted">Ce personnage a atteint le sommet officiel de la hiérarchie ninja.</p>
          {{/if}}
        </section>

        <section class="shinobi-v2-panel">
          <h2>Expérience</h2>

          <div class="shinobi-v2-data-grid">
            <div
              class="shinobi-v2-xp-total-control"
              data-v2-resource-control="experience"
              title="{{#if isGM}}MJ : cliquer pour accorder ou retirer de l’XP totale{{/if}}"
            >
              <strong>XP totale</strong>
              <span>{{v2.progression.experience.total}}</span>
            </div>
            <div><strong>XP dépensée</strong><span>{{v2.progression.experience.spent}}</span></div>
            <div><strong>XP Bases</strong><span>{{v2.progression.experience.baseSpent}}</span></div>
            <div><strong>XP Compétences</strong><span>{{v2.progression.experience.skillSpent}}</span></div>
            <div><strong>XP disponible</strong><span>{{v2.progression.experience.available}}</span></div>
          </div>
        </section>

        <section class="shinobi-v2-panel">
          <h2>Création / validation</h2>

          <div class="shinobi-v2-data-grid">
            <div><strong>État</strong><span>{{v2.creation.state.label}}</span></div>
            <div><strong>Mode</strong><span>{{v2.creation.mode}}</span></div>
            <div><strong>Compétences initiales</strong><span>{{v2.progression.creationSkillSummary.used}} / {{v2.progression.creationSkillSummary.max}}</span></div>
            <div><strong>Restantes</strong><span>{{v2.progression.creationSkillSummary.remaining}}</span></div>
          </div>

          {{#if v2.progression.creation.valid}}
            <div class="shinobi-v2-ok">Création conforme.</div>
          {{else}}
            <div class="shinobi-v2-warning">Création incomplète ou à corriger.</div>
          {{/if}}

          {{#if v2.progression.creation.errors.length}}
            <div class="shinobi-v2-warning">
              <strong>Erreurs</strong>
              <ul>
                {{#each v2.progression.creation.errors as |error|}}
                  <li>{{error}}</li>
                {{/each}}
              </ul>
            </div>
          {{/if}}

          {{#if v2.progression.creation.warnings.length}}
            <div class="shinobi-v2-warning">
              <strong>Avertissements</strong>
              <ul>
                {{#each v2.progression.creation.warnings as |warning|}}
                  <li>{{warning}}</li>
                {{/each}}
              </ul>
            </div>
          {{/if}}
        </section>

        <section class="shinobi-v2-panel">
          <h2>Missions</h2>

          <div class="shinobi-v2-mission-table">
            <div class="shinobi-v2-mission-row is-header">
              <span>Rang</span>
              <span>Réussies</span>
              <span>Échouées</span>
            </div>

            {{#each v2.progression.missions.ranks as |mission|}}
              <div class="shinobi-v2-mission-row">
                <strong>{{mission.label}}</strong>

                <input
                  name="system.missions.{{mission.key}}.completed"
                  type="number"
                  value="{{mission.data.completed}}"
                  min="0"
                  {{#unless @root.isGM}}disabled{{/unless}}
                />

                <input
                  name="system.missions.{{mission.key}}.failed"
                  type="number"
                  value="{{mission.data.failed}}"
                  min="0"
                  {{#unless @root.isGM}}disabled{{/unless}}
                />
              </div>
            {{/each}}
          </div>

          <div class="shinobi-v2-data-grid">
            <div><strong>Total réussies</strong><span>{{v2.progression.missions.totalCompleted}}</span></div>
            <div><strong>Total échouées</strong><span>{{v2.progression.missions.totalFailed}}</span></div>
          </div>
        </section>

      </div>

      <section class="shinobi-v2-panel">
        <h2>Bases</h2>

        <div class="shinobi-v2-bases-grid">
          {{#each v2.progression.bases as |base|}}
            <article class="shinobi-v2-base-card {{#if base.hasHiddenEffectiveValue}}has-effective-lineage{{/if}}">
              <header>
                <strong>{{base.label}}</strong>
                <span>{{base.value}} + {{base.bonus}}</span>
              </header>

              {{#if base.hasHiddenEffectiveValue}}
                <div class="shinobi-v2-warning">
                  Lignée effective : {{base.effectiveLineage}}.
                </div>
              {{/if}}

              <div class="shinobi-v2-base-controls">
                <button type="button" class="base-decrease" data-base="{{base.key}}" {{#unless base.canDecrease}}disabled{{/unless}}>-</button>
                <span>{{base.value}}</span>
                <button type="button" class="base-increase" data-base="{{base.key}}" {{#unless base.canIncrease}}disabled{{/unless}}>+</button>
              </div>

              <small>
                Cap {{base.cap}} · XP dépensée {{base.xpSpent}}
                {{#if base.nextCost}}· prochain coût {{base.nextCost}}{{/if}}
              </small>
            </article>
          {{/each}}
        </div>
      </section>

      <section class="shinobi-v2-panel">
        <h2>Compétences</h2>

        {{#each v2.progression.skillGroups as |group|}}
          <section class="shinobi-v2-subpanel">
            <h3>{{group.label}}</h3>

            <div class="shinobi-v2-skill-table">
              <div class="shinobi-v2-skill-row is-header">
                <span>Compétence</span>
                <span>Base</span>
                <span>Naturel</span>
                <span>Bonus</span>
                <span>Total</span>
                <span>Sources</span>
                <span>XP</span>
                <span>Contrôle</span>
              </div>

              {{#each group.skills as |skill|}}
                <div class="shinobi-v2-skill-row {{#unless skill.owned}}is-unowned{{/unless}}">
                  <strong class="shinobi-v2-skill-name">
                    <span>{{skill.label}}</span>

                    <span
                      class="shinobi-v2-help-badge"
                      title="{{skill.help}}"
                    >
                      ?
                    </span>
                  </strong>
                  <span>{{skill.baseLabel}}</span>
                  <span>{{skill.natural}}</span>
                  <span>{{skill.bonus}}</span>
                  <span>{{skill.total}}</span>

                  <span>
                    {{#if skill.sourceLabels.length}}
                      {{#each skill.sourceLabels as |source|}}
                        <em>{{source.label}}</em>
                      {{/each}}
                    {{else}}
                      —
                    {{/if}}
                  </span>

                  <span>
                    {{skill.xpSpent}}
                    {{#if skill.nextCost}}
                      / prochain {{skill.nextCost}}
                    {{/if}}
                  </span>

                  <span class="shinobi-v2-skill-controls">
                    <button type="button" class="skill-decrease" data-skill="{{skill.key}}" {{#unless skill.canDecrease}}disabled{{/unless}}>-</button>
                    <button type="button" class="skill-increase" data-skill="{{skill.key}}" {{#unless skill.canIncrease}}disabled{{/unless}}>+</button>
                  </span>
                </div>
              {{/each}}
            </div>
          </section>
        {{/each}}
      </section>
    </div>

        <div class="tab" data-group="primary" data-tab="effects">
      <div class="shinobi-v2-grid">

        <section class="shinobi-v2-panel shinobi-v2-effects-panel">
          <h2>Effets actifs / passifs</h2>

          <div class="shinobi-v2-effects-header">
            <p class="shinobi-v2-muted">
              {{v2.effects.count}} effet(s) visible(s)
              {{#if isGM}}sur {{v2.effects.total}} · {{v2.effects.hiddenCount}} caché(s){{/if}}.
              Actifs : {{v2.effects.activeCount}} · Inactifs : {{v2.effects.inactiveCount}} · États : {{v2.effects.conditionCount}} · Maintenus : {{v2.effects.maintainedCount}} · Passifs : {{v2.effects.passiveCount}}.
            </p>

            {{#if v2.effects.canAdd}}
              <div class="shinobi-v2-effects-actions">
                <button type="button" class="naruto-effect-add" data-category="condition">Ajouter état</button>
                <button type="button" class="naruto-effect-add" data-category="buff">Ajouter bonus</button>
                <button type="button" class="naruto-effect-add" data-category="custom">Ajouter effet</button>
              </div>
            {{/if}}
          </div>

          <p class="shinobi-v2-muted">
            V1 : les effets sont suivis et structurés ici, mais leurs modificateurs ne sont pas encore automatiquement appliqués aux jets, attaques ou dégâts.
          </p>

          {{#if v2.effects.items.length}}
            <div class="shinobi-v2-effects-list">
              {{#each v2.effects.items as |effect|}}
                <article class="shinobi-v2-effect-card is-effect-{{effect.tone}} {{#unless effect.enabled}}is-disabled{{/unless}} {{#if effect.isHidden}}is-hidden{{/if}}">
                  <header class="shinobi-v2-effect-header">
                    <label>
                      Nom
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="name"
                        type="text"
                        value="{{effect.name}}"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      />
                    </label>

                    <div class="shinobi-v2-effect-badges">
                      <span>{{effect.categoryLabel}}</span>
                      <span>{{effect.modeLabel}}</span>
                      <span>{{effect.durationLabel}}</span>
                      {{#if effect.isHidden}}
                        <span>MJ</span>
                      {{/if}}
                    </div>

                    <div class="shinobi-v2-effect-buttons">
                      {{#if @root.v2.effects.canEdit}}
                        <button
                          type="button"
                          class="naruto-effect-toggle"
                          data-effect-id="{{effect.id}}"
                        >
                          {{#if effect.enabled}}Désactiver{{else}}Activer{{/if}}
                        </button>

                        <button
                          type="button"
                          class="naruto-effect-delete"
                          data-effect-id="{{effect.id}}"
                        >
                          Supprimer
                        </button>
                      {{/if}}
                    </div>
                  </header>

                  <div class="shinobi-v2-form-grid">
                    <label>
                      Catégorie
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="category"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        {{#each @root.v2.effects.categoryOptions as |option|}}
                          <option value="{{option.key}}" {{#if (eq effect.category option.key)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      Mode
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="mode"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        {{#each @root.v2.effects.modeOptions as |option|}}
                          <option value="{{option.key}}" {{#if (eq effect.mode option.key)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      État / clé
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="statusKey"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        {{#each @root.v2.effects.statusOptions as |option|}}
                          <option value="{{option.key}}" {{#if (eq effect.statusKey option.key)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      Durée
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="durationType"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        {{#each @root.v2.effects.durationTypeOptions as |option|}}
                          <option value="{{option.key}}" {{#if (eq effect.durationType option.key)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      Source
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="sourceType"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        {{#each @root.v2.effects.sourceTypeOptions as |option|}}
                          <option value="{{option.key}}" {{#if (eq effect.sourceType option.key)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      Nom de source
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="sourceName"
                        type="text"
                        value="{{effect.sourceName}}"
                        placeholder="Technique, pouvoir, objet..."
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      />
                    </label>

                    <label>
                      Source UUID
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="sourceUuid"
                        type="text"
                        value="{{effect.sourceUuid}}"
                        placeholder="Item.xxxxx / Actor.xxxxx"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      />
                    </label>

                    <label>
                      Cible
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="targetType"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        {{#each @root.v2.effects.targetTypeOptions as |option|}}
                          <option value="{{option.key}}" {{#if (eq effect.targetType option.key)}}selected{{/if}}>{{option.label}}</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      Item ciblé
                      <select
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="targetItemId"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      >
                        <option value="">— Aucun item —</option>
                        {{#each @root.v2.effects.targetItems as |item|}}
                          <option value="{{item.id}}" {{#if (eq effect.targetItemId item.id)}}selected{{/if}}>{{item.name}} ({{item.type}})</option>
                        {{/each}}
                      </select>
                    </label>

                    <label>
                      Rounds restants
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="remainingRounds"
                        type="number"
                        min="0"
                        max="999"
                        value="{{effect.remainingRounds}}"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      />
                    </label>

                    <label>
                      Tours restants
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="remainingTurns"
                        type="number"
                        min="0"
                        max="999"
                        value="{{effect.remainingTurns}}"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      />
                    </label>

                    <label>
                      Entretien Chakra
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="maintenanceCost"
                        type="number"
                        min="0"
                        value="{{effect.maintenanceCost}}"
                        {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                      />
                    </label>

                    <div class="shinobi-v2-effect-rank-control">
                      <strong>Rang / intensité</strong>
                      <div>
                        {{#if @root.v2.effects.canEdit}}
                          <button type="button" class="naruto-effect-rank-adjust" data-effect-id="{{effect.id}}" data-delta="-1">-</button>
                        {{/if}}

                        <input
                          class="naruto-effect-field"
                          data-effect-id="{{effect.id}}"
                          data-field="rank"
                          type="number"
                          min="0"
                          max="10"
                          value="{{effect.rank}}"
                          {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                        />

                        {{#if @root.v2.effects.canEdit}}
                          <button type="button" class="naruto-effect-rank-adjust" data-effect-id="{{effect.id}}" data-delta="1">+</button>
                        {{/if}}
                      </div>
                    </div>
                  </div>

                  {{#if @root.v2.effects.canEditHidden}}
                    <label class="shinobi-v2-checkbox-line">
                      <input
                        class="naruto-effect-field"
                        data-effect-id="{{effect.id}}"
                        data-field="isHidden"
                        type="checkbox"
                        {{#if effect.isHidden}}checked{{/if}}
                      />
                      Effet caché, visible seulement par le MJ
                    </label>
                  {{/if}}

                  <label>
                    Notes
                    <textarea
                      class="naruto-effect-field"
                      data-effect-id="{{effect.id}}"
                      data-field="notes"
                      {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                    >{{effect.notes}}</textarea>
                  </label>

                  <label>
                    Notes de modificateurs futurs
                    <textarea
                      class="naruto-effect-field"
                      data-effect-id="{{effect.id}}"
                      data-field="modifierNotes"
                      placeholder="+X dégâts, malus de jet, arme ciblée, condition d’application..."
                      {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                    >{{effect.modifierNotes}}</textarea>
                  </label>

                  <div class="shinobi-v2-effect-modifiers">
                    <div class="shinobi-v2-effect-modifiers-header">
                      <strong>Modificateurs structurés</strong>

                      {{#if @root.v2.effects.canEdit}}
                        <button
                          type="button"
                          class="naruto-effect-modifier-add"
                          data-effect-id="{{effect.id}}"
                        >
                          Ajouter modificateur
                        </button>
                      {{/if}}
                    </div>

                    {{#if effect.modifiers.length}}
                      <div class="shinobi-v2-effect-modifier-list">
                        {{#each effect.modifiers as |modifier|}}
                          <div class="shinobi-v2-effect-modifier-row">
                            <label>
                              Cible
                              <select
                                class="naruto-effect-modifier-field"
                                data-effect-id="{{effect.id}}"
                                data-modifier-id="{{modifier.id}}"
                                data-field="target"
                                {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                              >
                                {{#each @root.v2.effects.modifierTargetOptions as |option|}}
                                  <option value="{{option.key}}" {{#if (eq modifier.target option.key)}}selected{{/if}}>{{option.label}}</option>
                                {{/each}}
                              </select>
                            </label>

                            <label>
                              Clé
                              <input
                                class="naruto-effect-modifier-field"
                                data-effect-id="{{effect.id}}"
                                data-modifier-id="{{modifier.id}}"
                                data-field="key"
                                type="text"
                                value="{{modifier.key}}"
                                placeholder="all, armesSimples, arm, tai, raiton..."
                                {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                              />
                            </label>

                            <label>
                              Valeur
                              <input
                                class="naruto-effect-modifier-field"
                                data-effect-id="{{effect.id}}"
                                data-modifier-id="{{modifier.id}}"
                                data-field="value"
                                type="number"
                                value="{{modifier.value}}"
                                {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                              />
                            </label>

                            <label>
                              Type
                              <select
                                class="naruto-effect-modifier-field"
                                data-effect-id="{{effect.id}}"
                                data-modifier-id="{{modifier.id}}"
                                data-field="type"
                                {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                              >
                                {{#each @root.v2.effects.modifierTypeOptions as |option|}}
                                  <option value="{{option.key}}" {{#if (eq modifier.type option.key)}}selected{{/if}}>{{option.label}}</option>
                                {{/each}}
                              </select>
                            </label>

                            <label class="is-wide">
                              Condition
                              <input
                                class="naruto-effect-modifier-field"
                                data-effect-id="{{effect.id}}"
                                data-modifier-id="{{modifier.id}}"
                                data-field="condition"
                                type="text"
                                value="{{modifier.condition}}"
                                placeholder="Ex : seulement avec Sharingan actif, arme ciblée, etc."
                                {{#unless @root.v2.effects.canEdit}}disabled{{/unless}}
                              />
                            </label>

                            {{#if @root.v2.effects.canEdit}}
                              <button
                                type="button"
                                class="naruto-effect-modifier-delete"
                                data-effect-id="{{effect.id}}"
                                data-modifier-id="{{modifier.id}}"
                              >
                                Supprimer
                              </button>
                            {{/if}}
                          </div>
                        {{/each}}
                      </div>
                    {{else}}
                      <p class="shinobi-v2-muted">Aucun modificateur structuré.</p>
                    {{/if}}
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="shinobi-v2-muted">Aucun effet visible.</p>
          {{/if}}
        </section>

      </div>
    </div>


  </section>
</form>