        <section class="shinobi-v2-panel">
          <h2>Lignée visible</h2>

          <div class="shinobi-v2-data-grid">
            <div><strong>Type</strong><span>{{v2.lineage.public.modeLabel}}</span></div>
            <div><strong>Héritage</strong><span>{{v2.lineage.public.heritageLabel}}</span></div>
