            <h2>Synthèse de lignée</h2>

            <div class="shinobi-v2-data-grid">
              <div><strong>Mode</strong><span>{{v2.lineage.modeLabel}}</span></div>
              <div><strong>Affichage public</strong><span>{{v2.lineage.public.heritageLabel}}</span></div>
              <div><strong>Clan principal</strong><span>{{v2.lineage.primaryClan.label}}</span></div>
