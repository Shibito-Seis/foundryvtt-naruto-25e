<form class="{{cssClass}} naruto-25e-shinobi-sheet" autocomplete="off">

  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />

    <div class="header-fields">
      <h1>
        <input name="name" type="text" value="{{actor.name}}" placeholder="Nom du ninja" />
      </h1>

      <div class="identity-grid">
        <label>
        Surnom Shinobi
        <input name="system.identity.prenom" type="text" value="{{system.identity.prenom}}" />
        </label>

        <label>
          Rang
        <input type="text" value="{{rankProgression.currentLabel}}" readonly />
        </label>
      </div>

      <div class="heritage-summary">
        <div>
          <strong>Village :</strong>
            <span>{{heritageSummary.village}}</span>
        </div>

        <div>
          <strong>Statut :</strong>
            <span>{{heritageSummary.status}}</span>
        </div>

        <div>
          <strong>Héritage :</strong>
            <span>{{heritageSummary.main}}</span>
        </div>

        <div>
          <strong>Type :</strong>
          <span>{{heritageSummary.mode}}</span>
        </div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
  <a class="item" data-tab="summary">Résumé</a>
  <a class="item" data-tab="background">Background</a>
  <a class="item" data-tab="effects">Effets / États</a>
  <a class="item" data-tab="combat">Combat / Actions</a>
  <a class="item" data-tab="chakra">Chakra</a>
  <a class="item" data-tab="inventory">Inventaire</a>
  <a class="item" data-tab="bases">Bases</a>
  <a class="item" data-tab="skills">Compétences</a>
  <a class="item" data-tab="heritage">Lignée</a>
  <a class="item" data-tab="missions">Missions</a>
  <a class="item" data-tab="progression">Progression</a>
  </nav>

  <section class="sheet-body">

    <div class="tab" data-group="primary" data-tab="summary">
      <div class="summary-grid">

        <section class="panel creation-panel {{#if creationState.locked}}is-locked{{else}}is-draft{{/if}}">
          <h2>Création</h2>

          <div class="creation-status">
            <strong>État :</strong>
            <span>{{creationState.label}}</span>
          </div>

          {{#if creationState.locked}}
            <p>
              Création validée
              {{#if creationState.validatedBy}}par {{creationState.validatedBy}}{{/if}}.
            </p>
          {{else}}
            <p>
              Cette fiche est encore en brouillon. Les choix fondateurs peuvent être ajustés avant validation.
            </p>
          {{/if}}

          <div class="creation-validation-summary {{#if creationValidation.valid}}is-valid{{else}}is-invalid{{/if}}">
            <h3>Résumé de création</h3>

            <div class="creation-summary-grid">
              <div>
                <strong>Village</strong>
                <span>{{creationValidation.summary.village}}</span>
              </div>

              <div>
                <strong>Statut</strong>
                <span>{{creationValidation.summary.status}}</span>
              </div>

              <div>
                <strong>Héritage</strong>
                <span>{{creationValidation.summary.heritage}}</span>
              </div>

              <div>
                <strong>Type</strong>
                <span>{{creationValidation.summary.heritageMode}}</span>
              </div>

              <div>
                <strong>Compétences initiales</strong>
                <span>
                  {{creationValidation.summary.initialSkillsUsed}} / {{creationValidation.summary.maxInitialSkills}}
                  — restantes : {{creationValidation.summary.initialSkillsRemaining}}
                </span>
              </div>

              <div>
                <strong>XP disponible</strong>
                <span>{{creationValidation.summary.xpAvailable}}</span>
              </div>
            </div>

            <div class="creation-affinity-summary">
              <strong>Affinités</strong>
              <div class="tag-list">
                {{#each creationValidation.summary.affinities as |affinity|}}
                  <span class="tag">{{affinity}}</span>
                {{/each}}
              </div>
            </div>

            {{#if creationValidation.valid}}
              <p class="creation-ok">Création conforme.</p>
            {{else}}
              <div class="creation-errors">
                <strong>Erreurs à corriger</strong>
                <ul>
                  {{#each creationValidation.errors as |error|}}
                    <li>{{error}}</li>
                  {{/each}}
                </ul>
              </div>
            {{/if}}
            {{#if creationValidation.warnings.length}}
              <div class="creation-warnings">
                <strong>Avertissements</strong>
                <ul>
                  {{#each creationValidation.warnings as |warning|}}
                    <li>{{warning}}</li>
                  {{/each}}
                </ul>
              </div>
            {{/if}}
          </div>

          <div class="button-row">
            {{#if creationState.canValidate}}
              <button
                type="button"
                class="creation-validate"
                {{#unless creationState.validationValid}}disabled{{/unless}}
                >
                Valider mon dossier
              </button>
            {{/if}}

            {{#if creationState.canUnlock}}
              <button type="button" class="creation-unlock">
                MJ : Déverrouiller la création
              </button>
            {{/if}}
          </div>
        </section>
      <section class="panel">
         <h2>Ressources</h2>

         <label>
          Vigueur
          <div class="resource-row">
           <input name="system.resources.vigueur.value" type="number" value="{{system.resources.vigueur.value}}" />
           <span>/</span>
           <input name="system.resources.vigueur.max" type="number" value="{{system.resources.vigueur.max}}" readonly />
          </div>
        </label>

        <label>
         Bonus Vigueur
          <input name="system.resources.vigueur.bonus" type="number" value="{{system.resources.vigueur.bonus}}" />
        </label>

        <label>
         Caractère
         <div class="resource-row">
          <input name="system.resources.caractere.value" type="number" value="{{system.resources.caractere.value}}" />
          <span>/</span>
          <input name="system.resources.caractere.max" type="number" value="{{system.resources.caractere.max}}" readonly />
         </div>
        </label>

        <label>
         Bonus Caractère
         <input name="system.resources.caractere.bonus" type="number" value="{{system.resources.caractere.bonus}}" />
        </label>

        <label>
         Chakra
         <div class="resource-row">
         <input name="system.resources.chakra.value" type="number" value="{{system.resources.chakra.value}}" />
         <span>/</span>

         {{#if (eq chakraFormulaMode "manual")}}
          <input name="system.resources.chakra.max" type="number" value="{{system.resources.chakra.max}}" />
         {{else}}
          <input name="system.resources.chakra.max" type="number" value="{{system.resources.chakra.max}}" readonly />
         {{/if}}
         </div>
        </label>
        <p class="formula-hint">
        Formule de Chakra : {{chakraFormulaMode}}
        </p>

        <label>
         Bonus Chakra
         <input name="system.resources.chakra.bonus" type="number" value="{{system.resources.chakra.bonus}}" />
        </label>

        <div class="resource-row">
        <label>
         Régén. passive
          <div class="readonly-value">
            <strong>{{system.resources.chakra.passiveRegen}}</strong>
            <span>({{system.resources.chakra.passiveRegenPercent}}% du Chakra max)</span>
          </div>
        </label>

        <span></span>

        <label>
          Régén. active
          <input name="system.resources.chakra.activeRegen" type="number" value="{{system.resources.chakra.activeRegen}}" />
        </label>
        </div>
      </section>

      <section class="naruto-panel naruto-kikaichu-reserve">
        <header class="naruto-panel-header">
          <h3>Réserve Kikaichū</h3>
        </header>

        {{#if system.resources.kikaichu.enabled}}
          <div class="naruto-resource-line">
            <label>Chakra général</label>
            <span>
              {{system.resources.chakra.value}} / {{system.resources.chakra.max}}
              <small>
                brut : {{system.resources.chakra.rawMax}}
              </small>
            </span>
          </div>

          <div class="naruto-resource-line">
            <label>Réserve Kikaichū</label>
            <span class="naruto-inline-resource">
              <input
              type="number"
              name="system.resources.kikaichu.value"
              value="{{system.resources.kikaichu.value}}"
              min="0"
              max="{{system.resources.kikaichu.allocated}}"
              step="1"
              data-dtype="Number"
              {{#unless system.resources.kikaichu.enabled}}disabled{{/unless}}
              />
              <span>/ {{system.resources.kikaichu.allocated}}</span>
            </span>
          </div>

          <div class="naruto-button-row">
            <button type="button" class="kikaichu-allocate" data-amount="-10">-10</button>
            <button type="button" class="kikaichu-allocate" data-amount="-5">-5</button>
            <button type="button" class="kikaichu-allocate" data-amount="5">+5</button>
            <button type="button" class="kikaichu-allocate" data-amount="10">+10</button>
          </div>

          <p class="hint">
            Le chakra alloué aux Kikaichū est retiré du chakra général utilisable.
          </p>
        {{else}}
          <p class="hint">
            Réserve inactive. Elle sera disponible pour les membres du clan Aburame.
          </p>
        {{/if}}
      </section>

  <section class="panel">
    <h2>État de combat</h2>

    <div class="combat-mini-state">
      <div>
        <strong>État manuel</strong>
        <span>{{combatSummary.manualStateLabel}}</span>
      </div>

      <div class="{{#if combatSummary.hasChakraAlert}}chakra-alert{{/if}}">
        <strong>État Chakra</strong>
        <span>{{combatSummary.chakraStateLabel}}</span>
      </div>
    </div>

    {{#if combatSummary.hasChakraAlert}}
      <p class="warning-text">
        Le niveau actuel de Chakra déclenche un palier automatique.
      </p>
    {{/if}}
  </section>

        <section class="panel">
          <h2>Nindō</h2>

          <section class="nindo-panel">
            <div class="nindo-grid">
              <div>
                <label>Type de Nindō</label>
                <select name="system.nindo.choiceMode" {{#unless permissionsState.canEditNindo}}disabled{{/unless}}>
                  {{#each nindoChoiceModes as |mode|}}
                    <option value="{{mode.key}}" {{#if mode.selected}}selected{{/if}}>
                      {{mode.label}}
                    </option>
                  {{/each}}
                </select>
              </div>

              <div>
                <label>Nindō prédéfini</label>
                <select name="system.nindo.preset" {{#unless permissionsState.canEditNindo}}disabled{{/unless}}>
                <option value="">— Aucun —</option>
                  {{#each nindoPresets as |preset|}}
                    <option value="{{preset.key}}" {{#if preset.selected}}selected{{/if}}>
                      {{preset.label}}
                    </option>
                  {{/each}}
                </select>
              </div>

              <div>
                <label>Points de Nindō</label>
                <input type="number" name="system.nindo.value" value="{{system.nindo.value}}" {{#unless isGM}}disabled{{/unless}} />
                <span>/ {{system.nindo.max}}</span>
              </div>

              <div>
                <label>Charges de Nindō</label>
                <input type="number" name="system.nindo.charges.value" value="{{system.nindo.charges.value}}" {{#unless isGM}}disabled{{/unless}} />
                <span>/ {{system.nindo.charges.max}}</span>
              </div>
            </div>

            <div class="nindo-current">
              <h3>{{nindoDisplay.name}}</h3>
              <p>{{nindoDisplay.description}}</p>
            </div>

            <div class="nindo-custom">
              <label>Nom du Nindō personnalisé</label>
              <input
                type="text"
                name="system.nindo.custom.name"
                value="{{system.nindo.custom.name}}"
                {{#unless permissionsState.canEditNindo}}disabled{{/unless}}
              />

              <label>Description personnalisée</label>
              <textarea
                name="system.nindo.custom.description"
                {{#unless permissionsState.canEditNindo}}disabled{{/unless}}
              >{{system.nindo.custom.description}}</textarea>
            </div>

            {{#if isGM}}
              <label class="checkbox-line">
                <input
                type="checkbox"
                name="system.nindo.unlockedByGM"
                {{#if system.nindo.unlockedByGM}}checked{{/if}}
                />
                MJ : autoriser temporairement le joueur à modifier son Nindō
              </label>
            {{/if}}

            <h3>Actions Nindō</h3>

            <div class="nindo-actions">
              {{#each nindoActions as |action|}}
                <div class="nindo-action-card">
                  <h4>{{action.label}}</h4>
                  <p><strong>Coût :</strong> {{action.cost}}{{#if action.variableCost}} à 3{{/if}} point(s)</p>
                  <p><strong>Temporalité :</strong> {{action.temporalite}}</p>
                  <p>{{action.description}}</p>

                  <button type="button" class="nindo-action-use" data-action="{{action.key}}">
                    Utiliser
                  </button>
                </div>
              {{/each}}
            </div>

            <h3>Charges de Dépassement</h3>

            <p>
              Charges disponibles :
              <strong>{{system.nindo.charges.value}} / {{system.nindo.charges.max}}</strong>
            </p>

            <button type="button" class="nindo-charge-spend" {{#unless system.nindo.charges.value}}disabled{{/unless}}>
              Dépenser une charge
            </button>

            {{#if system.nindo.activeEffects.chakraBoost.active}}
              <p class="nindo-active-effect">
                Accroissement du Chakra actif :
                +{{system.nindo.activeEffects.chakraBoost.amount}} Chakra,
                {{system.nindo.activeEffects.chakraBoost.remainingTurns}} tour(s) restant(s).
              </p>
            {{/if}}

            {{#if system.nindo.activeEffects.awakening.active}}
              <p class="nindo-active-effect">
                Éveil actif :
                {{system.nindo.activeEffects.awakening.actionsRemaining}} action(s) spéciale(s),
                bonus +{{system.nindo.activeEffects.awakening.bonus}}.
              </p>
            {{/if}}

            {{#if system.nindo.activeEffects.opportunity.available}}
              <p class="nindo-active-effect">
                Opportunité disponible grâce à Unison.
              </p>
            {{/if}}
          </section>

        <section class="panel">
          <h2>Spécialisations de Chakra</h2>

          <div class="chakra-spec-summary">
            <div>
              <strong>Choix dépensés</strong>
              <span>{{chakraSpecializationState.spent}} / {{chakraSpecializationState.available}}</span>
            </div>

            <div>
              <strong>Restants</strong>
              <span>{{chakraSpecializationState.remaining}}</span>
            </div>
          </div>

          {{#if chakraSpecializationSummary.length}}
            <ul class="chakra-spec-mini-list">
              {{#each chakraSpecializationSummary as |spec|}}
                <li>{{spec.text}}</li>
              {{/each}}
            </ul>
          {{else}}
            <p class="muted">Aucune spécialisation sélectionnée.</p>
          {{/if}}

          {{#if chakraSpecializationState.overLimit}}
            <p class="warning-text">
              Trop de spécialisations sélectionnées pour le rang actuel.
            </p>
          {{/if}}
        </section>

        <section class="panel">
          <h2>Expérience</h2>

          <label>
            XP totale
            <input name="system.progression.experience.total" type="number" value="{{system.progression.experience.total}}" />
          </label>

          <label>
            XP dépensée
            <input name="system.progression.experience.spent" type="number" value="{{system.progression.experience.spent}}" readonly />
          </label>

        <div class="xp-breakdown">
          <span>Bases : {{system.progression.experience.baseSpent}}</span>
          <span>Compétences : {{system.progression.experience.skillSpent}}</span>
        </div>

          <label>
            XP disponible
            <input name="system.progression.experience.available" type="number" value="{{system.progression.experience.available}}" readonly />
          </label>
        </section>

        <section class="panel">
          <h2>Inventaire</h2>

          <div class="combat-resource-line">
            <strong>Ryō</strong>
            <span>{{system.inventory.ryo}} 両</span>
          </div>

          <div class="combat-resource-line">
            <strong>Armes équipées</strong>
            <span>
              {{#if equippedWeapons.length}}
                {{#each equippedWeapons as |weapon|}}
                  {{weapon.name}}{{#unless @last}}, {{/unless}}
                {{/each}}
              {{else}}
                Aucune
              {{/if}}
            </span>
          </div>

          <div class="combat-resource-line">
            <strong>Protections équipées</strong>
            <span>
              {{#if equippedArmors.length}}
                {{#each equippedArmors as |armor|}}
                  {{armor.name}}{{#unless @last}}, {{/unless}}
                {{/each}}
              {{else}}
                Aucune
              {{/if}}
            </span>
          </div>
        </section>

      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="background">
      <section class="panel">
        <h2>Background</h2>

        <div class="summary-grid">
          <section class="panel">
            <h3>Nindō narratif</h3>

            <div class="combat-resource-line">
              <strong>Nindō actuel</strong>
              <span>{{nindoDisplay.name}}</span>
            </div>

            <p>{{nindoDisplay.description}}</p>

            <p class="formula-hint">
              Le Nindō se modifie depuis le bloc Nindō principal de l’onglet Résumé. Ce rappel est en lecture seule pour éviter les doublons de formulaire.
            </p>
          </section>

          <section class="panel">
            <h3>Identité narrative</h3>

            <label>
              Loyauté
              <textarea name="system.identity.loyalty" placeholder="Village, clan, équipe, idéaux...">{{system.identity.loyalty}}</textarea>
            </label>

            <label>
              Doctrine
              <textarea name="system.identity.doctrine" placeholder="Vision du devoir ninja, discipline, morale...">{{system.identity.doctrine}}</textarea>
            </label>

            <label>
              Vie quotidienne
              <textarea name="system.identity.dailyLife" placeholder="Habitudes, loisirs, famille, réputation...">{{system.identity.dailyLife}}</textarea>
            </label>

            <label>
              Religion / croyances
              <textarea name="system.identity.religion" placeholder="Croyances, superstitions, respect des kami, ancêtres...">{{system.identity.religion}}</textarea>
            </label>

            <label>
              Préjugés
              <textarea name="system.identity.prejudices" placeholder="Méfiances, biais culturels, rivalités...">{{system.identity.prejudices}}</textarea>
            </label>
          </section>
        </div>

        <section class="panel">
          <h3>Roue Narrative / Arcs narratifs</h3>

          <label>
            Arcs narratifs
            <textarea
              name="system.background.narrativeWheel.arcs"
              placeholder="Arcs claniques, personnels, héroïques, dramatiques..."
            >{{system.background.narrativeWheel.arcs}}</textarea>
          </label>

          <label>
            Balance narrative manuelle
            <input
              name="system.background.narrativeWheel.balance"
              type="number"
              value="{{system.background.narrativeWheel.balance}}"
            />
          </label>

          <label>
            Notes de Roue Narrative
            <textarea name="system.background.narrativeWheel.notes">{{system.background.narrativeWheel.notes}}</textarea>
          </label>

          <p class="formula-hint">
            Version préparatoire : la Roue Narrative complète sera affinée après le Charactomancer.
          </p>
        </section>

        <section class="panel">
          <h3>Notes de background</h3>
          <textarea name="system.background.notes">{{system.background.notes}}</textarea>
        </section>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="effects">
      <section class="panel">
        <h2>Effets / États</h2>

        <div class="summary-grid">
          <section class="panel">
            <h3>Pouvoirs de lignée actifs</h3>

            {{#if lineagePowerItems.length}}
              {{#each lineagePowerItems as |power|}}
                {{#if power.active}}
                  <div class="naruto-lineage-power-row is-active">
                    <div>
                      <strong>{{power.name}}</strong>
                      <span>{{power.typeLabel}}</span>
                      {{#if power.effect}}
                        <p class="formula-hint">{{power.effect}}</p>
                      {{/if}}
                    </div>
                  </div>
                {{/if}}
              {{/each}}
            {{else}}
              <p class="muted">Aucun pouvoir de lignée possédé.</p>
            {{/if}}

            <hr />

            <div class="combat-resource-line">
              <strong>Entretien total</strong>
              <span>{{lineageMaintenanceSummary.totalMaintenance}}</span>
            </div>

            <div class="combat-resource-line">
              <strong>Régénération passive</strong>
              <span>-{{lineageMaintenanceSummary.passiveRegen}}</span>
            </div>

            <div class="combat-resource-line">
              <strong>Coût net prochain tour</strong>
              <span>{{lineageMaintenanceSummary.netCost}}</span>
            </div>

            <div class="combat-resource-line">
              <strong>Chakra après entretien</strong>
              <span>{{lineageMaintenanceSummary.nextChakra}}</span>
            </div>

            {{#if lineageMaintenanceSummary.crossesCriticalThreshold}}
              <p class="warning-text">
                Attention : l’entretien risque de franchir un seuil critique de Chakra.
              </p>
            {{/if}}
          </section>

          <section class="panel">
            <h3>Pouvoirs de lignée passifs</h3>

            {{#if lineagePowerItems.length}}
              {{#each lineagePowerItems as |power|}}
                {{#if power.isPassive}}
                  <div class="naruto-lineage-power-row is-passive">
                    <div>
                      <strong>{{power.name}}</strong>
                      <span>Passif</span>
                      {{#if power.effect}}
                        <p class="formula-hint">{{power.effect}}</p>
                      {{/if}}
                    </div>
                  </div>
                {{/if}}
              {{/each}}
            {{else}}
              <p class="muted">Aucun pouvoir passif.</p>
            {{/if}}
          </section>
        </div>

        <section class="panel">
          <h3>États de combat</h3>

          <div class="combat-resource-line">
            <strong>État manuel</strong>
            <span>{{combatSummary.manualStateLabel}}</span>
          </div>

          <div class="combat-resource-line {{#if combatSummary.hasChakraAlert}}chakra-alert{{/if}}">
            <strong>État Chakra</strong>
            <span>{{combatSummary.chakraStateLabel}}</span>
          </div>

          <div class="combat-resource-line">
            <strong>Conditions</strong>
            <span>{{system.combat.health.conditions}}</span>
          </div>

          <div class="combat-resource-line">
            <strong>Aggravations</strong>
            <span>{{system.combat.health.aggravations}}</span>
          </div>

          <div class="combat-resource-line">
            <strong>Faiblesses</strong>
            <span>{{system.combat.health.weaknesses}}</span>
          </div>

          <div class="combat-resource-line">
            <strong>Notes de combat / blessures</strong>
            <span>{{system.combat.health.notes}}</span>
          </div>

          <p class="formula-hint">
            Ces champs se modifient depuis l’onglet Combat / Actions. Cet onglet affiche seulement le résumé des états.
          </p>
        </section>

        {{#if heritageState.hasUchihaLineage}}
          <section class="panel">
            <h3>Santé oculaire Uchiha</h3>

            <div class="summary-grid">
              <div class="combat-resource-line">
                <strong>Œil droit</strong>
                <span>{{heritageState.mangekyo.rightEyeStateLabel}}</span>
              </div>

              <div class="combat-resource-line">
                <strong>Pouvoir œil droit</strong>
                <span>{{heritageState.mangekyo.rightEyePowerLabel}}</span>
              </div>

              <div class="combat-resource-line">
                <strong>Œil gauche</strong>
                <span>{{heritageState.mangekyo.leftEyeStateLabel}}</span>
              </div>

              <div class="combat-resource-line">
                <strong>Pouvoir œil gauche</strong>
                <span>{{heritageState.mangekyo.leftEyePowerLabel}}</span>
              </div>
            </div>

            <div class="combat-resource-line">
              <strong>Utilisations Mangekyō</strong>
              <span>{{heritageState.mangekyo.uses}}</span>
            </div>

            <div class="combat-resource-line">
              <strong>Palier</strong>
              <span>{{heritageState.mangekyo.usageState.thresholdLabel}}</span>
            </div>

            {{#if heritageState.mangekyo.usageState.warning}}
              <p class="warning-text">
                {{heritageState.mangekyo.usageState.warning}}
              </p>
            {{/if}}

            <p class="formula-hint">
              Les réglages détaillés des yeux restent dans l’onglet Lignée.
            </p>
          </section>
        {{/if}}
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="combat">
      <section class="panel">
        <h2>Combat / Actions</h2>

        <div class="combat-grid">
          <section class="combat-card">
            <h3>Ressources rapides</h3>

              <div class="combat-resource-line">
                <strong>Vigueur</strong>
                <span>{{system.resources.vigueur.value}} / {{system.resources.vigueur.max}}</span>
              </div>

              <div class="combat-resource-line">
                <strong>Caractère</strong>
                <span>{{system.resources.caractere.value}} / {{system.resources.caractere.max}}</span>
              </div>

              <div class="combat-resource-line">
                <strong>Chakra</strong>
                <span>{{system.resources.chakra.value}} / {{system.resources.chakra.max}}</span>
              </div>

              <div class="combat-resource-line">
                <strong>Régén. passive</strong>
                <span>
                  {{system.resources.chakra.passiveRegen}}
                  ({{system.resources.chakra.passiveRegenPercent}}%)
                </span>
              </div>

              <div class="combat-resource-line">
                <strong>Régén. active</strong>
                <span>{{system.resources.chakra.activeRegen}}</span>
              </div>

              <section class="combat-card">
                <h3>Jet de compétence</h3>

                <label>
                  Compétence
                  <select name="system.combat.quickSkill">
                    <option value="">— Choisir —</option>
                      {{#each combatSkillOptions as |skill|}}
                        <option value="{{skill.key}}" {{#if skill.selected}}selected{{/if}}>
                      {{skill.label}}
                        </option>
                      {{/each}}
                  </select>
                </label>

                <button type="button" class="combat-roll-skill">
                  Lancer la compétence
                </button>

                <p class="formula-hint">
                  Jet : 1d10 explosif + total de compétence.
                </p>
              </section>

              <section class="combat-card">
                <h3>Compteurs</h3>

                <div class="combat-resource-line">
                  <strong>Interceptions ARM</strong>
                  <span>{{system.combat.counters.interceptions.arm.remaining}} / {{system.combat.counters.interceptions.arm.max}}</span>
                </div>

                <div class="combat-resource-line">
                  <strong>Interceptions TAI</strong>
                  <span>{{system.combat.counters.interceptions.tai.remaining}} / {{system.combat.counters.interceptions.tai.max}}</span>
                </div>

                {{#if isGM}}
                  <button type="button" class="combat-reset-counters" data-scope="round">
                    MJ : reset round
                  </button>
                {{/if}}

                <hr />

                <div class="combat-resource-line">
                  <strong>Utilisations de lignée de base</strong>
                  <span>{{system.combat.counters.lineagePowers.base}}</span>
                </div>

                <div class="combat-resource-line">
                  <strong>Pouvoirs de lignée</strong>
                  <span>
                    {{system.combat.counters.lineagePowers.remaining}} / {{system.combat.counters.lineagePowers.max}}
                    {{#if system.combat.counters.lineagePowers.bonus}}
                      (+{{system.combat.counters.lineagePowers.bonus}} Héréditaire)
                    {{/if}}
                  </span>
                </div>

                <div class="combat-resource-line">
                  <strong>Action de lignée ce tour</strong>
                  <span>
                    {{#if system.combat.counters.lineagePowers.usedThisTurn}}
                      Déjà utilisée
                    {{else}}
                      Disponible
                    {{/if}}
                  </span>
                </div>

                <button
                  type="button"
                  class="combat-spend-lineage-power"
                  {{#if system.combat.counters.lineagePowers.usedThisTurn}}disabled{{/if}}
                  {{#unless system.combat.counters.lineagePowers.remaining}}disabled{{/unless}}
                  >
                  Dépenser une utilisation de lignée
                </button>

                {{#if isGM}}
                  <button type="button" class="combat-reset-counters" data-scope="session">
                    MJ : reset session
                  </button>
                {{/if}}
              </section>
          </section>

          <section class="combat-card">
            <h3>Économie d’action</h3>

            <label>
              <input
                name="system.combat.actions.simpleAvailable"
                type="checkbox"
                {{checked system.combat.actions.simpleAvailable}}
              />
              Action simple disponible
            </label>

            <label>
              <input
                name="system.combat.actions.complexAvailable"
                type="checkbox"
                {{checked system.combat.actions.complexAvailable}}
              />
              Action complexe disponible
            </label>

            <label>
              <input
                name="system.combat.actions.delayedAvailable"
                type="checkbox"
                {{checked system.combat.actions.delayedAvailable}}
              />
              Action retardée en réserve
            </label>

            <label>
              Notes d’action
              <input
                name="system.combat.actions.notes"
                type="text"
                value="{{system.combat.actions.notes}}"
                placeholder="Dégainage, posture, action préparée..."
              />
            </label>
          </section>

          <section class="combat-card">
            <h3>Initiative</h3>

            <div class="combat-main-value">
              {{system.combat.initiative.formula}}
            </div>
            
            <button type="button" class="combat-roll-initiative">
              Lancer l’initiative
            </button>

            <label>
              Bonus Initiative
              <input name="system.combat.initiative.bonus" type="number" value="{{system.combat.initiative.bonus}}" />
            </label>

            <p class="formula-hint">
              Base actuelle : Physique = {{system.combat.initiative.base}}
              {{#if system.combat.initiative.specializationBonus}}
                | Bonus spécialisation : +{{system.combat.initiative.specializationBonus}}
              {{/if}}
            </p>
          </section>

          <section class="combat-card">
            <h3>Attaques basiques</h3>

              <div class="combat-resource-line">
                <strong>ARM</strong>
                <span>{{system.combat.attacks.arm.total}}</span>
              </div>
              
              <button type="button" class="combat-roll-attack" data-kind="arm">
                Attaque ARM
              </button>

              <label>
                Bonus attaque ARM
                <input name="system.combat.attacks.arm.bonus" type="number" value="{{system.combat.attacks.arm.bonus}}" />
              </label>

              <div class="combat-resource-line">
                <strong>TAI</strong>
                <span>{{system.combat.attacks.tai.total}}</span>
              </div>
              
              <button type="button" class="combat-roll-attack" data-kind="tai">
                Attaque TAI
              </button>

              <label>
                Bonus attaque TAI
                <input name="system.combat.attacks.tai.bonus" type="number" value="{{system.combat.attacks.tai.bonus}}" />
              </label>
          </section>

          <section class="combat-card">
            <h3>Dégâts basiques</h3>

            <div class="combat-resource-line">
              <strong>Dégâts ARM</strong>
              <span>{{system.combat.damage.arm.total}}</span>
            </div>

            <label>
              Bonus arme provisoire
              <input name="system.combat.damage.arm.weaponBonus" type="number" value="{{system.combat.damage.arm.weaponBonus}}" />
            </label>

            <label>
              Bonus dégâts ARM
              <input name="system.combat.damage.arm.bonus" type="number" value="{{system.combat.damage.arm.bonus}}" />
            </label>

            <p class="formula-hint">
              Formule : COR + ARM + bonus arme + bonus divers.
            </p>

            <div class="combat-resource-line">
              <strong>Dégâts TAI</strong>
              <span>{{system.combat.damage.tai.total}}</span>
            </div>

            <label>
              Bonus dégâts TAI
              <input name="system.combat.damage.tai.bonus" type="number" value="{{system.combat.damage.tai.bonus}}" />
            </label>

            <p class="formula-hint">
              Formule : COR + TAI + bonus divers.
            </p>
          </section>

          <section class="combat-card">
            <h3>Interceptions</h3>

            <div class="combat-resource-line">
              <strong>Interception ARM</strong>
              <span>
                {{system.combat.counters.interceptions.arm.remaining}} / {{system.combat.counters.interceptions.arm.max}}
                — jet +{{system.combat.interceptions.arm.rollTotal}}
              </span>
            </div>

            <button
              type="button"
              class="combat-roll-interception"
              data-kind="arm"
              {{#unless system.combat.counters.interceptions.arm.remaining}}disabled{{/unless}}
              >
              Intercepter ARM
            </button>

            <label>
              Bonus interception ARM
              <input name="system.combat.interceptions.arm.bonus" type="number" value="{{system.combat.interceptions.arm.bonus}}" />
            </label>

            <div class="combat-resource-line">
              <strong>Interception TAI</strong>
              <span>
                {{system.combat.counters.interceptions.tai.remaining}} / {{system.combat.counters.interceptions.tai.max}}
                — jet +{{system.combat.interceptions.tai.rollTotal}}
              </span>
            </div>

            <button
              type="button"
              class="combat-roll-interception"
              data-kind="tai"
              {{#unless system.combat.counters.interceptions.tai.remaining}}disabled{{/unless}}
              >
              Intercepter TAI
            </button>

            <label>
              Bonus interception TAI
              <input name="system.combat.interceptions.tai.bonus" type="number" value="{{system.combat.interceptions.tai.bonus}}" />
            </label>
            <p class="formula-hint">
              Table : score 1 = 1 interception, 4 = 2, 6 = 3, 8 = 4, 10 = 5. Le bonus ajoute des interceptions, pas un bonus au jet.
            </p>
          </section>

        <section class="combat-card">
            <h3>Santé</h3>

            <label>
              Palier manuel
              <select name="system.combat.health.manualState">
                {{#each combatHealthStates as |state|}}
                  <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                    {{state.label}}
                  </option>
                {{/each}}
              </select>
            </label>

          <div class="combat-resource-line {{#if combatSummary.hasChakraAlert}}chakra-alert{{/if}}">
            <strong>Palier Chakra</strong>
            <span>{{combatSummary.chakraStateLabel}}</span>
          </div>

          <div class="health-track">
            <span>Fatigue 1</span>
            <span>Fatigue 2</span>
            <span>Sonné</span>
            <span>Blessure 1</span>
            <span>Blessure 2</span>
            <span>Blessure 3</span>
          </div>

          <hr />

          <h4>Calculateur de blessures</h4>

          <label>
            Dégâts entrants
            <input
              name="system.combat.health.woundCalculator.incomingDamage"
              type="number"
              value="{{system.combat.health.woundCalculator.incomingDamage}}"
            />
          </label>

          <label>
            Défense ciblée
            <select name="system.combat.health.woundCalculator.defense">
              <option value="vigueur" {{#if (eq system.combat.health.woundCalculator.defense "vigueur")}}selected{{/if}}>Vigueur</option>
              <option value="caractere" {{#if (eq system.combat.health.woundCalculator.defense "caractere")}}selected{{/if}}>Caractère</option>
            </select>
          </label>

          <label>
            Type de dégâts
            <select name="system.combat.health.woundCalculator.damageType">
              <option value="PHY" {{#if (eq system.combat.health.woundCalculator.damageType "PHY")}}selected{{/if}}>PHY</option>
              <option value="ELEM" {{#if (eq system.combat.health.woundCalculator.damageType "ELEM")}}selected{{/if}}>ELEM</option>
              <option value="ENVI" {{#if (eq system.combat.health.woundCalculator.damageType "ENVI")}}selected{{/if}}>ENVI</option>
              <option value="EMO" {{#if (eq system.combat.health.woundCalculator.damageType "EMO")}}selected{{/if}}>EMO</option>
              <option value="PSY" {{#if (eq system.combat.health.woundCalculator.damageType "PSY")}}selected{{/if}}>PSY</option>
              <option value="MYTH" {{#if (eq system.combat.health.woundCalculator.damageType "MYTH")}}selected{{/if}}>MYTH</option>
            </select>
          </label>

          <button type="button" class="combat-calculate-wounds">
            Calculer les blessures
          </button>
        </section>

        <section class="combat-card">
          <h3>Réserves de lignée</h3>

          <label class="{{#unless system.combat.health.reserves.lineageA.enabled}}disabled-field{{/unless}}">
            <input
              name="system.combat.health.reserves.lineageA.checked"
              type="checkbox"
              {{checked system.combat.health.reserves.lineageA.checked}}
              {{#unless system.combat.health.reserves.lineageA.enabled}}disabled{{/unless}}
            />
            Lignée A
          </label>

          <label class="{{#unless system.combat.health.reserves.lineageB.enabled}}disabled-field{{/unless}}">
            <input
              name="system.combat.health.reserves.lineageB.checked"
              type="checkbox"
              {{checked system.combat.health.reserves.lineageB.checked}}
              {{#unless system.combat.health.reserves.lineageB.enabled}}disabled{{/unless}}
            />
            Lignée B
          </label>

          {{#if isGM}}
            <hr />

            <label>
              <input
                name="system.combat.health.reserves.lineageA.enabled"
                type="checkbox"
                {{checked system.combat.health.reserves.lineageA.enabled}}
              />
              MJ : autoriser Lignée A
            </label>

            <label>
              <input
                name="system.combat.health.reserves.lineageB.enabled"
                type="checkbox"
                {{checked system.combat.health.reserves.lineageB.enabled}}
              />
              MJ : autoriser Lignée B
            </label>
          {{/if}}
        </section>
        </div>

        <section class="combat-card combat-notes">
          <h3>Conditions / blessures</h3>

          <label>
            Conditions
            <textarea name="system.combat.health.conditions">{{system.combat.health.conditions}}</textarea>
          </label>

          <label>
            Aggravations
            <textarea name="system.combat.health.aggravations">{{system.combat.health.aggravations}}</textarea>
          </label>

          <label>
            Faiblesses
            <textarea name="system.combat.health.weaknesses">{{system.combat.health.weaknesses}}</textarea>
          </label>

          <label>
            Notes de combat / blessures
            <textarea name="system.combat.health.notes">{{system.combat.health.notes}}</textarea>
          </label>
        </section>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="chakra">
      <section class="panel">
        <h2>Chakra / Spécialisations</h2>

        <section class="chakra-affinities-panel">
          <h3>Affinités de Chakra</h3>

          <div class="chakra-affinity-grid">
            <label>
              Affinité principale
              <select name="system.chakra.affinities.primary" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
                <option value="">— Aucune —</option>
                {{#each chakraAffinityOptions as |affinity|}}
                  <option value="{{affinity.key}}" {{#if affinity.primarySelected}}selected{{/if}}>
                    {{affinity.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Affinité secondaire
              <select name="system.chakra.affinities.secondary" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
                <option value="">— Aucune —</option>
                {{#each chakraAffinityOptions as |affinity|}}
                  <option value="{{affinity.key}}" {{#if affinity.secondarySelected}}selected{{/if}}>
                    {{affinity.label}}
                  </option>
                {{/each}}
              </select>
            </label>
          </div>

          <section class="creation-preview-section">
            <h3>Aide de création — Affinités</h3>

            <div class="creation-preview-grid">
              {{#each chakraAffinityOptions as |affinity|}}
                <article class="creation-preview-card">
                  <header>
                    <h4>{{affinity.label}}</h4>
                    <div class="tag-list">
                      {{#each affinity.previewTags as |tag|}}
                        <span class="tag">{{tag}}</span>
                      {{/each}}
                    </div>
                  </header>

                  <p>{{affinity.description}}</p>

                  {{#if affinity.playstyle}}
                    <p><strong>Style :</strong> {{affinity.playstyle}}</p>
                  {{/if}}

                  {{#if affinity.strengths.length}}
                    <div>
                      <strong>Forces</strong>
                      <ul>
                        {{#each affinity.strengths as |strength|}}
                          <li>{{strength}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}

                  {{#if affinity.weaknesses.length}}
                    <div>
                      <strong>Limites</strong>
                      <ul>
                        {{#each affinity.weaknesses as |weakness|}}
                          <li>{{weakness}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}

                  {{#if affinity.associatedSkills.length}}
                    <div>
                      <strong>Compétences associées</strong>
                      <div class="tag-list">
                        {{#each affinity.associatedSkills as |skill|}}
                          <span class="tag">{{skill.label}}</span>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}

                  {{#if affinity.recommendedFor.length}}
                    <div>
                      <strong>Conseillé pour</strong>
                      <ul>
                        {{#each affinity.recommendedFor as |advice|}}
                          <li>{{advice}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}
                </article>
              {{/each}}
            </div>
          </section>

          <div class="chakra-affinity-summary">
            <p>
              <strong>Mode de coût :</strong>
              {{affinityCostMode}}
            </p>

            <p>
              <strong>Principale :</strong> {{chakraAffinitySummary.primary}}
              |
              <strong>Secondaire :</strong> {{chakraAffinitySummary.secondary}}
            </p>

            {{#if chakraAffinitySummary.forced.length}}
              <div>
                <strong>Affinités imposées par clan :</strong>
                <ul>
                  {{#each chakraAffinitySummary.forced as |affinity|}}
                    <li>{{affinity.label}} → compétence {{affinity.skillLabel}}</li>
                  {{/each}}
                </ul>
              </div>
            {{else}}
              <p class="muted">Aucune affinité imposée par le clan actuellement.</p>
            {{/if}}

            {{#if chakraAffinitySummary.owned.length}}
              <div>
                <strong>Compétences accordées par affinité :</strong>
                <ul>
                  {{#each chakraAffinitySummary.owned as |affinity|}}
                    <li>{{affinity.label}} → {{affinity.skillLabel}}</li>
                  {{/each}}
                </ul>
              </div>
            {{/if}}
          </div>

          <label>
            Notes sur les affinités
            <textarea name="system.chakra.affinities.notes" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>{{system.chakra.affinities.notes}}</textarea>
          </label>
        </section>

        <div class="chakra-spec-header">
          <div>
            <strong>Rang actuel</strong>
            <span>{{rankProgression.currentLabel}}</span>
          </div>

          <div>
            <strong>Emplacements</strong>
            <span>{{chakraSpecializationState.spent}} / {{chakraSpecializationState.available}}</span>
          </div>

          <div>
            <strong>Restants</strong>
            <span>{{chakraSpecializationState.remaining}}</span>
          </div>
        </div>

        {{#if chakraSpecializationState.overLimit}}
          <p class="warning-text">
            Ce personnage possède plus de spécialisations que son rang ne le permet.
          </p>
        {{/if}}

        <section class="chakra-bonus-panel">
        <h3>Bonus actifs</h3>

          <div class="chakra-bonus-grid">
            <span>Chakra max : +{{chakraSpecializationBonuses.chakraMax}}</span>
            <span>Vigueur max : +{{chakraSpecializationBonuses.vigueurMax}}</span>
            <span>Caractère max : +{{chakraSpecializationBonuses.caractereMax}}</span>
            <span>Initiative : +{{chakraSpecializationBonuses.initiative}}</span>
            <span>Déplacement simple : +{{chakraSpecializationBonuses.moveMeters}} m</span>
            <span>Dégâts ARM : +{{chakraSpecializationBonuses.armDamage}}</span>
            <span>Dégâts TAI : +{{chakraSpecializationBonuses.taiDamage}}</span>
            <span>Régénération passive : +{{chakraSpecializationBonuses.passiveRegenPercent}}%</span>
            <span>Pouvoirs de lignée actifs : +{{chakraSpecializationBonuses.lineagePowerUses}}</span>
          </div>
        </section>

        <section class="chakra-specializations-list">
        <h3>Spécialisations disponibles</h3>

          {{#each chakraSpecializations as |spec|}}
            <div class="chakra-spec-card {{#if spec.specialOnly}}special-only{{/if}}">
              <div class="chakra-spec-main">
                <div>
                  <h4>{{spec.label}}</h4>
                  <p>{{spec.effect}}</p>

                    {{#if spec.unique}}
                      <span class="chakra-spec-tag">Unique</span>
                    {{else}}
                      <span class="chakra-spec-tag">Max {{spec.maxStacks}}</span>
                    {{/if}}
                </div>

                <div class="chakra-spec-controls">
                  <button
                    type="button"
                    class="chakra-specialization-decrease"
                    data-specialization="{{spec.key}}"
                    {{#unless spec.canDecrease}}disabled{{/unless}}
                    >
                    −
                  </button>

                  <input type="number" value="{{spec.value}}" readonly />

                  <button
                    type="button"
                    class="chakra-specialization-increase"
                    data-specialization="{{spec.key}}"
                    {{#unless spec.canIncrease}}disabled{{/unless}}
                    >
                    +
                  </button>
                </div>
              </div>
            </div>
          {{/each}}
        </section>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="bases">
  <section class="panel">
    <h2>Bases</h2>

    <div class="base-cap-info">
      Plafond actuel des Bases : <strong>{{baseCap}}</strong>
    </div>

    <section class="xp-reminder">
      <strong>XP disponible :</strong> {{experienceSummary.available}}
      <span>— Total : {{experienceSummary.total}}</span>
      <span>— Dépensée Bases : {{experienceSummary.baseSpent}}</span>
    </section>

    <div class="bases-grid">
      {{#each bases as |base|}}
        <div class="base-card">
          <label>{{base.label}}</label>

          <div class="base-controls">
            <button type="button" class="base-decrease" data-base="{{base.key}}" {{#unless base.canDecrease}}disabled{{/unless}}>
              −
            </button>

            <input name="system.bases.{{base.key}}.value" type="number" value="{{base.value}}" readonly />

            <button type="button" class="base-increase" data-base="{{base.key}}" {{#unless base.canIncrease}}disabled{{/unless}}>
              +
            </button>
          </div>

          <small>Bonus</small>
          <input name="system.bases.{{base.key}}.bonus" type="number" value="{{base.bonus}}" />

          <div class="base-xp-info">
            <span>XP investie : {{base.xpSpent}}</span>
            <span>
              Prochain rang :
              {{#if base.nextCost}}
                {{base.nextCost}} XP
              {{else}}
                —
              {{/if}}
            </span>
          </div>

          {{#if base.hasHiddenEffectiveValue}}
            <div class="creation-warnings">
              <strong>Lignée effective verrouillée</strong>
              <p>
                Lignée effective : {{base.effectiveLineage}} malgré une Base brute de {{base.value}}.
              </p>
            </div>
          {{/if}}
        </div>
      {{/each}}
    </div>
  </section>
</div>

    <div class="tab" data-group="primary" data-tab="skills">
    <section class="panel">
    <h2>Compétences</h2>

    <section class="xp-reminder">
      <strong>XP disponible :</strong> {{experienceSummary.available}}
      <span>— Total : {{experienceSummary.total}}</span>
      <span>— Dépensée Compétences : {{experienceSummary.skillSpent}}</span>
    </section>

    <section class="creation-skill-summary {{#if creationSkillSummary.overLimit}}is-invalid{{/if}}">
      <strong>Compétences initiales :</strong>
      {{creationSkillSummary.used}} / {{creationSkillSummary.max}}

      {{#if creationSkillSummary.overLimit}}
        <span class="creation-error">
          — Limite dépassée.
        </span>
      {{else}}
        <span>
          — Restantes : {{creationSkillSummary.remaining}}
        </span>
      {{/if}}
    </section>

      {{#each skillGroups as |group|}}
        <section class="skill-group">
          <h3>{{group.label}}</h3>

          <table class="skills-table">
            <thead>
              <tr>
                <th>Nom</th>
                <th>Base</th>
                <th>Score</th>
                <th>Bonus</th>
                <th>Total</th>
                <th>XP</th>
                <th>Prochain</th>
                <th>Maîtrise</th>
                <th>Possédée</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              {{#each group.skills as |skill|}}
                <tr class="{{#unless skill.owned}}skill-unowned{{/unless}}">
                  <td>{{skill.label}}</td>
                  <td>{{skill.baseLabel}}</td>
                  <td>
                    <div class="skill-controls">
                      <button type="button" class="skill-decrease" data-skill="{{skill.key}}" {{#unless skill.canDecrease}}disabled{{/unless}}>
                        −
                      </button>

                      <input name="system.skills.{{skill.key}}.natural" type="number" value="{{skill.natural}}" readonly />

                      <button type="button" class="skill-increase" data-skill="{{skill.key}}" {{#unless skill.canIncrease}}disabled{{/unless}}>
                        +
                      </button>
                    </div>
                  </td>
                  <td>
                    <input name="system.skills.{{skill.key}}.bonus" type="number" value="{{skill.bonus}}" />
                  </td>
                  <td>
                    <input type="number" value="{{skill.total}}" readonly />
                  </td>
                  <td>{{skill.xpSpent}}</td>
                  <td>
                    {{#if skill.canIncrease}}
                      {{skill.nextCost}} XP
                    {{else}}
                      —
                    {{/if}}
                  </td>
                  <td>{{skill.masteryLabel}}</td>
                  <td>
                    <input
                      name="system.skills.{{skill.key}}.owned"
                      type="checkbox"
                      {{#if skill.owned}}checked{{/if}}
                      {{#unless skill.canToggleOwned}}disabled{{/unless}}
                    />
                  </td>
                  <td>
                    {{#if skill.sourceLabels.length}}
                      <div class="skill-source-list">
                        {{#each skill.sourceLabels as |source|}}
                          <span class="skill-source-badge source-{{source.key}}">
                            {{source.label}}
                          </span>
                        {{/each}}
                      </div>
                    {{else}}
                    —
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </section>
      {{/each}}
    </section>
    </div>

    <div class="tab" data-group="primary" data-tab="heritage">
    <section class="panel">
      <h2>Lignée / Clan / Voie</h2>
        {{#if isGM}}
          <section class="gm-heritage-options">
          <h3>Options MJ de cette fiche</h3>

            <label class="checkbox-row">
              <input
                type="checkbox"
                class="heritage-gm-option"
                data-field="allowHybridClan"
                {{#if heritageState.allowHybridClan}}checked{{/if}}
              />
              Autoriser le Clan hybride
            </label>

            <label class="checkbox-row">
              <input
                type="checkbox"
                class="heritage-gm-option"
                data-field="allowHybridVoie"
                {{#if heritageState.allowHybridVoie}}checked{{/if}}
              />
              Autoriser la Voie hybridée
            </label>

            <label class="checkbox-row">
              <input
                type="checkbox"
                class="heritage-gm-option"
                data-field="allowCustomClan"
                {{#if heritageState.allowCustomClan}}checked{{/if}}
              />
              Autoriser le Clan custom
            </label>

            {{#if heritageState.hasUchihaLineage}}
              <hr />

              <h4>Éveils Uchiha</h4>

              <div class="creation-preview-card">
                <h4>{{heritageState.uchihaPowerModeData.label}}</h4>
                <p>{{heritageState.uchihaPowerModeData.summary}}</p>
                <p class="hint">{{heritageState.uchihaPowerModeData.warning}}</p>

                {{#if (eq heritageState.uchihaPowerMode "original")}}
                  <div class="creation-warning-list">
                    <strong>Règles importantes</strong>
                    <ul>
                      <li>Amaterasu, Tsukuyomi, Kamui et Kotoamatsukami ne sont pas automatiques.</li>
                      <li>L’œil droit débloque son choix à Lignée 6.</li>
                      <li>L’œil gauche débloque son choix à Lignée 7.</li>
                      <li>Enton / Kagutsuchi ne peut pas être le premier pouvoir d’œil : il nécessite Amaterasu sur l’œil droit.</li>
                      <li>Izanagi et Izanami ne nécessitent pas le Mangekyō, mais sacrifient l’œil utilisé.</li>
                      <li>Le Susanō reste un pouvoir supérieur à part, destiné à une future fiche/progression dédiée.</li>
                    </ul>
                  </div>

                  <div>
                    <strong>Pouvoirs oculaires disponibles</strong>
                    <ul>
                      {{#each heritageState.uchihaEyePowers as |power|}}
                        <li>
                          <strong>{{power.label}}</strong> — {{power.summary}}
                          {{#if power.requiresOtherEyePower}}
                            <br />
                            <span class="hint">Condition croisée : nécessite {{power.requiresOtherEyePower}} dans l’autre œil.</span>
                          {{/if}}
                        </li>
                      {{/each}}
                    </ul>
                  </div>

                  <section class="uchiha-mangekyo-panel">
                    <h4>Choix du Mangekyō</h4>

                    <div class="uchiha-eye-grid">
                      <div class="uchiha-eye-card">
                        <h5>Œil droit</h5>
                        <p class="hint">
                          Débloqué à Lignée {{heritageState.mangekyo.rightEyeMinimumLineage}}.
                        </p>

                        {{#unless heritageState.mangekyo.rightEyeChoiceUnlocked}}
                          <p class="warning-text">
                            L’œil droit n’est pas encore disponible.
                          </p>
                        {{/unless}}

                        <label>
                          Pouvoir
                          <select
                            class="uchiha-eye-power-choice"
                            data-eye="right"
                            {{#unless heritageState.mangekyo.canEditRightEye}}disabled{{/unless}}
                          >
                            <option value="">— Aucun —</option>
                            {{#each heritageState.mangekyo.rightEyePowerOptions as |power|}}
                              <option value="{{power.key}}" {{#if power.selected}}selected{{/if}} {{#if power.disabled}}disabled{{/if}}>
                                {{power.label}}
                              </option>
                            {{/each}}
                          </select>
                        </label>

                        {{#unless heritageState.mangekyo.rightEyeValidation.valid}}
                          <p class="warning-text">{{heritageState.mangekyo.rightEyeValidation.reason}}</p>
                        {{/unless}}

                        <div class="uchiha-validation-row">
                          <button
                            type="button"
                            class="uchiha-eye-player-validate"
                            data-eye="right"
                            {{#unless heritageState.mangekyo.canValidateRightEyeAsPlayer}}disabled{{/unless}}
                          >
                            Confirmer PJ
                          </button>

                          <span class="tag">
                            PJ : {{#if heritageState.mangekyo.rightEyePlayerValidated}}validé{{else}}à confirmer{{/if}}
                          </span>
                        </div>

                        {{#if isGM}}
                          <label class="checkbox-row">
                            <input
                              type="checkbox"
                              class="uchiha-eye-gm-validate"
                              data-eye="right"
                              {{#if heritageState.mangekyo.rightEyeGmValidated}}checked{{/if}}
                              {{#unless heritageState.mangekyo.rightEyePlayerValidated}}disabled{{/unless}}
                            />
                            Validation MJ
                          </label>

                          <button type="button" class="uchiha-eye-reset" data-eye="right">
                            MJ : annuler validation
                          </button>
                        {{/if}}

                        <label>
                          État de l’œil
                          <select class="uchiha-eye-state" data-eye="right" {{#unless isGM}}disabled{{/unless}}>
                            {{#each heritageState.mangekyo.rightEyeStateOptions as |state|}}
                              <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                                {{state.label}}
                              </option>
                            {{/each}}
                          </select>
                        </label>
                      </div>

                      <div class="uchiha-eye-card">
                        <h5>Œil gauche</h5>
                        <p class="hint">
                          Débloqué à Lignée {{heritageState.mangekyo.leftEyeMinimumLineage}}.
                        </p>

                        {{#unless heritageState.mangekyo.leftEyeChoiceUnlocked}}
                          <p class="warning-text">
                            L’œil gauche n’est pas encore disponible.
                          </p>
                        {{/unless}}

                        {{#if heritageState.mangekyo.leftEyeChoiceLocked}}
                          <p class="hint">
                            L’œil gauche se débloque après confirmation PJ de l’œil droit.
                          </p>
                        {{/if}}

                        <label>
                          Pouvoir
                          <select
                            class="uchiha-eye-power-choice"
                            data-eye="left"
                            {{#unless heritageState.mangekyo.canEditLeftEye}}disabled{{/unless}}
                          >
                            <option value="">— Aucun —</option>
                            {{#each heritageState.mangekyo.leftEyePowerOptions as |power|}}
                              <option value="{{power.key}}" {{#if power.selected}}selected{{/if}} {{#if power.disabled}}disabled{{/if}}>
                                {{power.label}}
                              </option>
                            {{/each}}
                          </select>
                        </label>

                        {{#unless heritageState.mangekyo.leftEyeValidation.valid}}
                          <p class="warning-text">{{heritageState.mangekyo.leftEyeValidation.reason}}</p>
                        {{/unless}}

                        <div class="uchiha-validation-row">
                          <button
                            type="button"
                            class="uchiha-eye-player-validate"
                            data-eye="left"
                            {{#unless heritageState.mangekyo.canValidateLeftEyeAsPlayer}}disabled{{/unless}}
                          >
                            Confirmer PJ
                          </button>

                          <span class="tag">
                            PJ : {{#if heritageState.mangekyo.leftEyePlayerValidated}}validé{{else}}à confirmer{{/if}}
                          </span>
                        </div>

                        {{#if isGM}}
                          <label class="checkbox-row">
                            <input
                              type="checkbox"
                              class="uchiha-eye-gm-validate"
                              data-eye="left"
                              {{#if heritageState.mangekyo.leftEyeGmValidated}}checked{{/if}}
                              {{#unless heritageState.mangekyo.leftEyePlayerValidated}}disabled{{/unless}}
                            />
                            Validation MJ
                          </label>

                          <button type="button" class="uchiha-eye-reset" data-eye="left">
                            MJ : annuler validation
                          </button>
                        {{/if}}

                        <label>
                          État de l’œil
                          <select class="uchiha-eye-state" data-eye="left" {{#unless isGM}}disabled{{/unless}}>
                            {{#each heritageState.mangekyo.leftEyeStateOptions as |state|}}
                              <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                                {{state.label}}
                              </option>
                            {{/each}}
                          </select>
                        </label>
                      </div>
                    </div>

                    <div class="uchiha-mangekyo-usage">
                      <h5>Santé oculaire du Mangekyō</h5>

                      <div class="uchiha-usage-grid">
                        <div>
                          <strong>Utilisations</strong>
                          <span>{{heritageState.mangekyo.usageState.uses}} / 50</span>
                        </div>

                        <div>
                          <strong>État</strong>
                          <span>{{heritageState.mangekyo.usageState.thresholdLabel}}</span>
                        </div>

                        <div>
                          <strong>Malus Vigilance conseillé</strong>
                          <span>-{{heritageState.mangekyo.usageState.vigilancePenalty}}</span>
                        </div>
                      </div>

                      <div class="button-row">
                        <button type="button" class="mangekyo-uses-adjust" data-delta="-1">-1 utilisation</button>
                        <button type="button" class="mangekyo-uses-adjust" data-delta="1">+1 utilisation</button>
                      </div>

                      <p class="hint">{{heritageState.mangekyo.usageState.warning}}</p>

                      {{#if heritageState.mangekyo.usageState.shouldSeekEms}}
                        <p class="warning-text">
                          Quête EMS recommandée : le personnage devrait chercher une solution narrative avant la cécité.
                        </p>
                      {{/if}}

                      {{#if heritageState.mangekyo.usageState.blindThresholdReached}}
                        <p class="warning-text">
                          Seuil de cécité atteint : le MJ devrait marquer les yeux comme aveugles, sauf EMS/Rinnegan ou exception narrative.
                        </p>
                      {{/if}}

                      <label>
                        Notes Mangekyō
                        <textarea name="system.heritage.uchiha.mangekyo.notes">{{system.heritage.uchiha.mangekyo.notes}}</textarea>
                      </label>
                    </div>
                  </section>
                {{/if}}
              </div>

              <label class="checkbox-row">
                <input
                  type="checkbox"
                  class="heritage-gm-option"
                  data-field="hasMangekyoSharingan"
                  {{#if heritageState.hasMangekyoSharingan}}checked{{/if}}
                />
                Mangekyō Sharingan éveillé
              </label>

              <p class="hint">
                Validation MJ : traumatisme narratif majeur. Les rangs Uchiha 5+ restent verrouillés tant que cette option n’est pas cochée.
              </p>

              <label class="checkbox-row">
                <input
                  type="checkbox"
                  class="heritage-gm-option"
                  data-field="hasEternalMangekyoSharingan"
                  {{#if heritageState.hasEternalMangekyoSharingan}}checked{{/if}}
                  {{#unless heritageState.hasMangekyoSharingan}}disabled{{/unless}}
                />
                Mangekyō Sharingan Éternel
              </label>

              <p class="hint">
                Nécessite le Mangekyō Sharingan et l’implantation des yeux d’un membre d’une même fratrie.
              </p>

              {{#unless heritageState.hasSenjuLineage}}
                <label class="checkbox-row">
                  <input
                    type="checkbox"
                    class="heritage-gm-option"
                    data-field="hasSenjuCells"
                    {{#if heritageState.hasSenjuCellsByImplant}}checked{{/if}}
                  />
                  Cellules Senju implantées
                </label>

                <p class="hint">
                  Validation MJ : implantation réussie, avec conséquences narratives ou médicales possibles.
                </p>
              {{else}}
                <p class="hint">
                  Cellules Senju : présentes naturellement via lignée / hybridation Senju.
                </p>
              {{/unless}}

              <label class="checkbox-row">
                <input
                  type="checkbox"
                  class="heritage-gm-option"
                  data-field="hasRinnegan"
                  {{#if heritageState.hasRinnegan}}checked{{/if}}
                  {{#unless heritageState.canAwakenRinnegan}}disabled{{/unless}}
                />
                Rinnegan éveillé / validé
              </label>

              <p class="hint">
                Nécessite Uchiha, Mangekyō Sharingan ou EMS, et cellules Senju.
              </p>
            {{/if}}

            {{#if heritageState.hasHyugaLineage}}
              <hr />

              <h4>Éveil Hyūga</h4>

              <label class="checkbox-row">
                <input
                  type="checkbox"
                  class="heritage-gm-option"
                  data-field="hasTenseigan"
                  {{#if heritageState.hasTenseigan}}checked{{/if}}
                />
                Tenseigan éveillé / validé
              </label>

              <p class="hint">
                Validation MJ : éveil rare du Byakugan supérieur, réservé aux lignées Hyūga.
              </p>
            {{/if}}
          </section>
        {{/if}}

      <div class="identity-grid">
        <label>
          Village d’origine
          <select name="system.heritage.village" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
            {{#each villages as |village|}}
              <option value="{{village.key}}" {{#if village.selected}}selected{{/if}} {{#unless village.selectable}}disabled{{/unless}}>
                {{village.label}}{{#unless village.selectable}} — indisponible{{/unless}}
              </option>
            {{/each}}
          </select>
        </label>

        <label>
          Statut
          <select name="system.heritage.villageStatus" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
            {{#each villageStatuses as |status|}}
              <option value="{{status.key}}" {{#if status.selected}}selected{{/if}}>
                {{status.label}}
              </option>
            {{/each}}
          </select>
        </label>

        <label>
          Type d’héritage
          <select class="heritage-mode-select" name="system.heritage.mode" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
            {{#each heritageModes as |mode|}}
              <option value="{{mode.key}}" {{#if mode.selected}}selected{{/if}} {{#if mode.disabled}}disabled{{/if}}>
                {{mode.label}}{{#if mode.disabled}} — option MJ requise{{/if}}
              </option>
            {{/each}}
          </select>
        </label>

        <label>
          Clan principal
          <select name="system.heritage.clan" {{#if heritageState.clanDisabled}}disabled{{else}}{{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}{{/if}}>
            <option value="">Aucun clan sélectionné</option>
            {{#each clans as |clan|}}
              <option value="{{clan.key}}" {{#if clan.selected}}selected{{/if}}>
                {{clan.label}}
              </option>
            {{/each}}
          </select>
        </label>

        <label>
          Voie
          <select name="system.heritage.voie" {{#if heritageState.voieDisabled}}disabled{{else}}{{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}{{/if}}>
            <option value="">Aucune voie sélectionnée</option>
            {{#each voies as |voie|}}
              <option value="{{voie.key}}" {{#if voie.selected}}selected{{/if}} {{#unless voie.selectable}}disabled{{/unless}}>
                {{voie.label}}{{#unless voie.selectable}} — indisponible{{/unless}}
              </option>
            {{/each}}
          </select>
        </label>

        <label>
          Clan secondaire / hybridation
          <select name="system.heritage.hybrid.secondaryClan" {{#if heritageState.hybridDisabled}}disabled{{else}}{{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}{{/if}}>
            <option value="">Aucun</option>
            {{#each secondaryClans as |clan|}}
              <option value="{{clan.key}}" {{#if clan.selected}}selected{{/if}}>
                {{clan.label}}
              </option>
            {{/each}}
          </select>
        </label>
        {{#if heritageState.isHiddenClanMode}}
          {{#if heritageState.canSeeHiddenClan}}
            <label>
              Clan officiel / social
              <select
                class="hidden-clan-field"
                data-field="officialClan"
                {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}
              >
                <option value="">Aucun clan officiel</option>
                {{#each hiddenClanOfficialClans as |clan|}}
                  <option value="{{clan.key}}" {{#if clan.selected}}selected{{/if}}>
                    {{clan.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Réel Clan
              <select
                class="hidden-clan-field"
                data-field="realClan"
                {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}
              >
                <option value="">Aucun réel clan</option>
                {{#each hiddenClanRealClans as |clan|}}
                  <option value="{{clan.key}}" {{#if clan.selected}}selected{{/if}}>
                    {{clan.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              État de connaissance
              <select
                class="hidden-clan-field"
                data-field="awareness"
                {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}
              >
                {{#each hiddenClanAwarenessStates as |state|}}
                  <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                    {{state.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            {{#if isGM}}
              <label class="checkbox-row">
                <input
                  type="checkbox"
                  class="hidden-clan-field"
                  data-field="unlocked"
                  {{#if heritageState.hiddenClan.unlocked}}checked{{/if}}
                />
                MJ : lignée réelle débloquée
              </label>
            {{/if}}
          {{/if}}
        {{/if}}
      </div>

      {{#if heritageState.isHiddenClanMode}}
        <section class="lineage-section">
          <h3>Clan caché / dissimulé</h3>

          {{#if heritageState.canSeeHiddenClan}}
            <div class="creation-preview-card">
              <p>
                <strong>Clan officiel :</strong>
                {{heritageState.hiddenClan.officialClanLabel}}
              </p>

              <p>
                <strong>Réel Clan :</strong>
                {{heritageState.hiddenClan.realClanLabel}}
              </p>

              <p>
                <strong>État :</strong>
                {{heritageState.hiddenClan.awarenessLabel}}
              </p>

              <p class="hint">
                {{heritageState.hiddenClan.awarenessSummary}}
              </p>

              {{#if heritageState.hiddenClan.unlocked}}
                <p class="creation-ok">
                  Lignée réelle débloquée : la progression normale peut reprendre.
                </p>
              {{else}}
                <p class="warning-text">
                  Lignée réelle verrouillée : progression limitée par l’état narratif actuel.
                </p>
              {{/if}}

              <label>
                Notes de lignée cachée
                <textarea
                  class="hidden-clan-field"
                  data-field="notes"
                  {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}
                >{{heritageState.hiddenClan.notes}}</textarea>
              </label>
            </div>
          {{else}}
            <p class="hint">
              Cette fiche affiche uniquement le clan officiel connu. Les informations de lignée réelle sont réservées au propriétaire et au MJ.
            </p>
          {{/if}}
        </section>
      {{/if}}

        <label>
          Raison / origine de l’hybridation
          <textarea name="system.heritage.hybrid.reason" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>{{system.heritage.hybrid.reason}}</textarea>
        </label>

      {{#if heritageState.isCustomClanMode}}
        <section class="lineage-section">
          <h3>Clan custom</h3>

          <p class="hint">
            Fondation préparatoire : le clan custom est un clan principal spécial, soumis à validation MJ. Il peut imposer jusqu’à 2 choix au total : compétences normales ou affinités.
          </p>

          <div class="identity-grid">
            <label>
              Nom du clan custom
              <input
                type="text"
                name="system.heritage.customClan.name"
                value="{{system.heritage.customClan.name}}"
                {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}
              />
            </label>

            <label>
              Résumé court
              <input
                type="text"
                name="system.heritage.customClan.summary"
                value="{{system.heritage.customClan.summary}}"
                {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}
              />
            </label>

            <label>
              Choix imposé 1
              <select name="system.heritage.customClan.mandatoryChoices.0" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
                <option value="">Aucun</option>
                {{#each customClanChoiceOptions as |choice|}}
                  <option value="{{choice.key}}" {{#if choice.selectedFirst}}selected{{/if}}>
                    {{choice.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Choix imposé 2
              <select name="system.heritage.customClan.mandatoryChoices.1" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>
                <option value="">Aucun</option>
                {{#each customClanChoiceOptions as |choice|}}
                  <option value="{{choice.key}}" {{#if choice.selectedSecond}}selected{{/if}}>
                    {{choice.label}}
                  </option>
                {{/each}}
              </select>
            </label>
          </div>

          <label>
            Notes MJ / lore du clan custom
            <textarea name="system.heritage.customClan.notes" {{#unless permissionsState.canEditLockedCreationFields}}disabled{{/unless}}>{{system.heritage.customClan.notes}}</textarea>
          </label>
        </section>
      {{/if}}

      <label>
        Notes de lignée
        <textarea name="system.heritage.notes">{{system.heritage.notes}}</textarea>
      </label>

      {{#if clanCreationPreviews.length}}
        <section class="creation-preview-section">
          <h3>Aide de création — Clan</h3>

          <div class="creation-preview-grid">
            {{#each clanCreationPreviews as |clan|}}
              <article class="creation-preview-card">
                <header>
                  <h4>{{clan.role}} — {{clan.label}}</h4>
                  <div class="tag-list">
                    {{#each clan.previewTags as |tag|}}
                      <span class="tag">{{tag}}</span>
                    {{/each}}
                  </div>
                </header>

                {{#if clan.summary}}
                  <p><strong>Résumé :</strong> {{clan.summary}}</p>
                {{/if}}

                {{#if clan.lore}}
                  <p><strong>Lore :</strong> {{clan.lore}}</p>
                {{/if}}

                {{#if clan.creationAdvice}}
                  <p><strong>Conseil de création :</strong> {{clan.creationAdvice}}</p>
                {{/if}}

                {{#if clan.mandatorySkills.length}}
                  <div>
                    <strong>Compétences obligatoires</strong>
                    <div class="tag-list">
                      {{#each clan.mandatorySkills as |skill|}}
                        <span class="tag">{{skill.label}}</span>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if clan.mandatoryAffinities.length}}
                  <div>
                    <strong>Affinités imposées</strong>
                    <div class="tag-list">
                      {{#each clan.mandatoryAffinities as |affinity|}}
                        <span class="tag">{{affinity.label}}</span>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                {{#if clan.startingFeatures.length}}
                  <div>
                    <strong>Départ</strong>
                    <ul>
                      {{#each clan.startingFeatures as |feature|}}
                        <li>{{feature}}</li>
                      {{/each}}
                    </ul>
                  </div>
                {{/if}}

                {{#if clan.futureUnlocks.length}}
                  <div>
                    <strong>Déblocages futurs</strong>
                    <ul>
                      {{#each clan.futureUnlocks as |unlock|}}
                        <li>{{unlock}}</li>
                      {{/each}}
                    </ul>
                  </div>
                {{/if}}

                {{#if clan.narrativeWarnings.length}}
                  <div class="creation-warning-list">
                    <strong>Attention narrative</strong>
                    <ul>
                      {{#each clan.narrativeWarnings as |warning|}}
                        <li>{{warning}}</li>
                      {{/each}}
                    </ul>
                  </div>
                {{/if}}

                {{#if clan.recommendedBuilds.length}}
                  <div>
                    <strong>Archétypes conseillés</strong>
                    <div class="tag-list">
                      {{#each clan.recommendedBuilds as |build|}}
                        <span class="tag">{{build}}</span>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}
              </article>
            {{/each}}
          </div>
        </section>
      {{/if}}

      <section class="lineage-section">
        <h3>Compétences obligatoires de lignée</h3>

        {{#if lineageInfo.hasMandatorySkills}}
          <ul class="lineage-mandatory-skills">
            {{#each heritageMandatorySkills as |entry|}}
              <li>
                <strong>{{entry.skillLabel}}</strong>
                <span>— {{entry.clanLabel}} / {{entry.sourceLabel}}</span>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="muted">Aucune compétence obligatoire de clan actuellement liée.</p>
        {{/if}}
      </section>

      <section class="lineage-section">
        <h3>Pouvoirs de lignée possédés</h3>

        {{#if hasLineagePowerItems}}
          <div class="naruto-lineage-power-list">
            {{#each lineagePowerItems as |power|}}
              <div class="naruto-lineage-power-row {{#if power.active}}is-active{{/if}} {{#if power.isPassive}}is-passive{{/if}}">
                <div>
                  <strong>{{power.name}}</strong>

                  {{#if power.isPassive}}
                    <span>
                      Passif — ne consomme pas d’utilisation de lignée.
                    </span>
                  {{else}}
                    <span>
                      Activation {{power.activationCost}} —
                      Entretien {{power.maintenanceCost}} / tour
                    </span>
                  {{/if}}

                  {{#if power.effect}}
                    <p class="formula-hint">{{power.effect}}</p>
                  {{/if}}
                </div>

                {{#if power.isActivable}}
                  <button
                    type="button"
                    class="lineage-power-toggle"
                    data-item-id="{{power.id}}"
                  >
                    {{#if power.active}}Désactiver{{else}}Activer{{/if}}
                  </button>
                {{else}}
                  <span class="tag">Passif</span>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class="muted">
            Aucun pouvoir de lignée possédé pour le moment.
          </p>
        {{/if}}

        <div class="naruto-lineage-maintenance-summary">
          <h4>Entretien actif</h4>

          <div class="maintenance-grid">
            <div>
              <strong>Pouvoirs actifs</strong>
              <span>{{lineageMaintenanceSummary.activeCount}}</span>
            </div>

            <div>
              <strong>Entretien total</strong>
              <span>{{lineageMaintenanceSummary.totalMaintenance}}</span>
            </div>

            <div>
              <strong>Régénération passive</strong>
              <span>-{{lineageMaintenanceSummary.passiveRegen}}</span>
            </div>

            <div>
              <strong>Coût net / tour</strong>
              <span>{{lineageMaintenanceSummary.netCost}}</span>
            </div>

            <div>
              <strong>Chakra après entretien</strong>
              <span>{{lineageMaintenanceSummary.nextChakra}}</span>
            </div>
          </div>

          {{#if lineageMaintenanceSummary.crossesCriticalThreshold}}
            <p class="warning-text">
              Attention : l’entretien ferait franchir un seuil critique de Chakra.
            </p>
          {{/if}}

          <p class="formula-hint">
            Les coûts d’entretien sont cumulés, puis la régénération passive est soustraite une seule fois.
          </p>
        </div>

        {{#if isGM}}
          <button type="button" class="lineage-power-upkeep-check">
            MJ : tester / résoudre l’entretien
          </button>
        {{/if}}
      </section>

      <section class="lineage-section">
        <h3>Capacités de lignée</h3>

        <p class="lineage-help">
        Base Lignée actuelle : <strong>{{lineageInfo.value}}</strong>.
        Les capacités ci-dessous sont affichées selon les rangs réels de lignée.
        </p>

        {{#if lineageInfo.hasTracks}}
          {{#each lineageTracks as |track|}}
            <div class="naruto-lineage-track">
              <h4>{{track.role}} — {{track.label}}</h4>

              <div class="naruto-lineage-ranks">
                {{#each track.ranks as |rank|}}
                    <div class="naruto-lineage-rank {{#if rank.unlocked}}is-unlocked{{else}}is-locked{{/if}} {{#if rank.narrativeLocked}}is-narrative-locked{{/if}} {{#if rank.current}}is-current{{/if}}">
                    <div class="naruto-lineage-rank-header">
                      {{#if rank.narrativeLocked}}
                        <span class="naruto-tag narrative-locked">Validation MJ requise</span>
                      {{/if}}
                      <strong>Rang {{rank.rank}}</strong>

                      <span class="naruto-tag {{#if rank.unlocked}}unlocked{{else}}locked{{/if}}">
                        {{#if rank.unlocked}}Déverrouillé{{else}}Verrouillé{{/if}}
                      </span>

                      {{#if rank.current}}
                        <span class="naruto-tag current">Rang actuel</span>
                      {{/if}}
                    </div>

                    {{#if rank.narrativeLocked}}
                      <p class="naruto-lineage-lock-warning">
                        {{rank.lockReason}}
                      </p>
                    {{/if}}

                    {{#if rank.hasFeatures}}
                      {{#each rank.features as |feature|}}
                        <div class="naruto-lineage-feature">
                          <h5>{{feature.label}}{{#unless feature.label}}{{feature.title}}{{/unless}}</h5>

                          {{#if feature.type}}
                            <div class="naruto-lineage-rank-type">{{feature.type}}</div>
                          {{/if}}

                          {{#if feature.summary}}
                            <p class="naruto-lineage-rank-summary">{{feature.summary}}</p>
                          {{/if}}

                          {{#if feature.description}}
                            <p class="naruto-lineage-rank-summary">{{feature.description}}</p>
                          {{/if}}

                          {{#if feature.mechanical}}
                            <p class="naruto-lineage-rank-mechanical">
                              <strong>Effet :</strong> {{feature.mechanical}}
                            </p>
                          {{/if}}
                        </div>
                      {{/each}}
                    {{else}}
                      <p class="muted">{{rank.placeholder}}</p>
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            </div>
          {{/each}}
          {{else}}
            <p class="muted">Aucune piste de lignée à afficher pour ce mode d’héritage.</p>
        {{/if}}
      </section>
    </section>
    </div>

    <div class="tab" data-group="primary" data-tab="inventory">
      <section class="panel">
        <h2>Inventaire</h2>

        <section class="panel">
          <h2>Ryō</h2>

          <div class="ryo-display">
            <strong>Fortune actuelle :</strong>
            <span>{{system.inventory.ryo}} 両</span>
          </div>

          {{#if permissionsState.canEditRyo}}
            <div class="ryo-controls">
              <input name="system.inventory.ryoDelta" type="number" value="{{system.inventory.ryoDelta}}" min="0" placeholder="Montant" />

              <button type="button" class="ryo-adjust" data-mode="add">
                Ajouter
              </button>

              <button type="button" class="ryo-adjust" data-mode="remove">
                Retirer
              </button>
            </div>
          {{else}}
            <p class="hint">
              Les Ryō sont gérés par le MJ.
            </p>
          {{/if}}

          {{#if isGM}}
            <label class="checkbox-line">
              <input class="ryo-permission-toggle" type="checkbox" {{#if permissionsState.allowPlayerRyoEdit}}checked{{/if}} />
              MJ : autoriser ce joueur à modifier ses Ryō
            </label>
          {{/if}}
        </section>

        <section class="inventory-summary-panel {{system.inventory.encumbrance.statusClass}}">
          <h3>Résumé d’inventaire</h3>

          <div class="inventory-summary-grid">
            <div>
              <strong>Objets</strong>
              <span>{{system.inventory.summary.totalItems}}</span>
            </div>

            <div>
              <strong>Poids total</strong>
              <span>{{system.inventory.summary.totalWeight}}</span>
            </div>

            <div>
              <strong>Poids équipé</strong>
              <span>{{system.inventory.summary.equippedWeight}}</span>
            </div>

            <div>
              <strong>Valeur totale</strong>
              <span>{{system.inventory.summary.totalValue}} 両</span>
            </div>
          </div>

          <div class="inventory-value-grid">
            <div>
              <strong>Armes</strong>
              <span>{{system.inventory.summary.valueByType.weapon}} 両</span>
            </div>

            <div>
              <strong>Protections</strong>
              <span>{{system.inventory.summary.valueByType.armor}} 両</span>
            </div>

            <div>
              <strong>Consommables</strong>
              <span>{{system.inventory.summary.valueByType.consumable}} 両</span>
            </div>

            <div>
              <strong>Objets</strong>
              <span>{{system.inventory.summary.valueByType.misc}} 両</span>
            </div>
          </div>

          <div class="inventory-encumbrance">
            <h4>Poids indicatif</h4>

            <div class="inventory-encumbrance-grid">
              <div>
                <strong>COR</strong>
                <span>{{system.inventory.encumbrance.cor}}</span>
              </div>

              <div>
                <strong>Poids porté</strong>
                <span>{{system.inventory.encumbrance.current}}</span>
              </div>

              <div>
                <strong>État</strong>
                <span>{{system.inventory.encumbrance.label}}</span>
              </div>
            </div>

            <p class="inventory-encumbrance-penalty">
              {{system.inventory.encumbrance.penaltyText}}
            </p>
          </div>
        </section>

        <section class="inventory-summary-panel">
          <h3>Toxicité / drogues</h3>

          <div class="inventory-summary-grid">
            <div>
              <strong>Total</strong>
              <span>{{system.consumables.toxicity.value}} / {{system.consumables.toxicity.max}}</span>
            </div>

            <div>
              <strong>Jour</strong>
              <span>{{system.consumables.toxicity.dailyValue}} / {{system.consumables.toxicity.dailyMax}}</span>
            </div>

            <div>
              <strong>Semaine</strong>
              <span>{{system.consumables.toxicity.weeklyValue}} / {{system.consumables.toxicity.weeklyMax}}</span>
            </div>
          </div>

          {{#if isGM}}
            <div class="button-row">
              <button type="button" class="toxicity-reset" data-toxicity-reset="day">
                MJ : reset jour
              </button>

              <button type="button" class="toxicity-reset" data-toxicity-reset="week">
                MJ : reset semaine
              </button>

              <button type="button" class="toxicity-reset" data-toxicity-reset="all">
                MJ : reset total
              </button>
            </div>
          {{/if}}

          <label>
            Notes toxicité
            <textarea name="system.consumables.toxicity.notes">{{system.consumables.toxicity.notes}}</textarea>
          </label>
        </section>

        <section class="inventory-add-panel">
          <h3>Ajouter un objet</h3>

          <div class="inventory-add-grid">
            <label>
              Nom
              <input name="system.inventory.newItem.name" type="text" value="{{system.inventory.newItem.name}}" />
            </label>

            <label>
              Type
              <select name="system.inventory.newItem.type">
                {{#each inventoryTypes as |type|}}
                  <option value="{{type.key}}" {{#if type.selected}}selected{{/if}}>
                    {{type.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Quantité
              <input name="system.inventory.newItem.quantity" type="number" value="{{system.inventory.newItem.quantity}}" min="1" />
            </label>

            <button type="button" class="inventory-add-item">
              Ajouter
            </button>
          </div>
        </section>

        {{#each inventoryByType as |group|}}
          <section class="inventory-group">
            <h3>{{group.label}}</h3>

            {{#if group.items.length}}
              <div class="inventory-table">
                <div class="inventory-row inventory-header-row">
                  <span>Nom</span>
                  <span>Qté</span>
                  <span>Valeur</span>
                  <span>Poids</span>
                  <span>Tenue</span>
                  <span>Notes</span>
                  <span>Action</span>
                  <span></span>
                </div>

                {{#each group.items as |item|}}
                  <div class="inventory-row">
                    <input
                      class="inventory-item-field"
                      data-item-id="{{item.id}}"
                      data-field="name"
                      type="text"
                      value="{{item.name}}"
                    />

                    <input
                      class="inventory-item-field"
                      data-item-id="{{item.id}}"
                      data-field="quantity"
                      type="number"
                      value="{{item.quantity}}"
                      min="1"
                    />

                    {{#if ../../permissionsState.canEditInventoryEconomy}}
                      <input
                        class="inventory-item-field"
                        data-item-id="{{item.id}}"
                        data-field="value"
                        type="number"
                        value="{{item.value}}"
                        min="0"
                      />
                    {{else}}
                      <span>{{item.value}}</span>
                    {{/if}}

                    {{#if ../../permissionsState.canEditInventoryEconomy}}
                      <input
                        class="inventory-item-field"
                        data-item-id="{{item.id}}"
                        data-field="weight"
                        type="number"
                        value="{{item.weight}}"
                        min="0"
                      />
                    {{else}}
                      <span>{{item.weight}}</span>
                    {{/if}}

                    {{#if item.carryOptions.length}}
                      <select
                        class="inventory-carry-state"
                        data-item-id="{{item.id}}"
                      >
                        {{#each item.carryOptions as |state|}}
                          <option value="{{state.key}}" {{#if state.selected}}selected{{/if}}>
                            {{state.label}}
                          </option>
                        {{/each}}
                      </select>
                    {{else}}
                      <span class="muted">—</span>
                    {{/if}}

                    <input
                      class="inventory-item-field"
                      data-item-id="{{item.id}}"
                      data-field="notes"
                      type="text"
                      value="{{item.notes}}"
                    />

                    {{#if (eq item.type "consumable")}}
                      <button
                        type="button"
                        class="inventory-use-consumable"
                        data-item-id="{{item.id}}"
                        title="Utiliser"
                      >
                        Utiliser
                      </button>
                    {{else}}
                      <span class="muted">—</span>
                    {{/if}}

                    <button
                      type="button"
                      class="inventory-delete-item"
                      data-item-id="{{item.id}}"
                      title="Supprimer"
                    >
                      ✕
                    </button>
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="muted">Aucun élément.</p>
            {{/if}}
          </section>
        {{/each}}
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="missions">
      <section class="panel">
        <h2>Missions</h2>

        <table>
          <thead>
            <tr>
              <th>Rang</th>
              <th>Réussies</th>
              <th>Échouées</th>
            </tr>
          </thead>

          <tbody>
            {{#each missionRanks as |mission|}}
              <tr>
              <td>{{mission.label}}</td>

              <td>
                <input
                  name="system.missions.{{mission.key}}.completed"
                  type="number"
                  value="{{mission.data.completed}}"
                  min="0"
                  {{#unless ../isGM}}disabled{{/unless}}
                />
              </td>

              <td>
                <input
                  name="system.missions.{{mission.key}}.failed"
                  type="number"
                  value="{{mission.data.failed}}"
                  min="0"
                  {{#unless ../isGM}}disabled{{/unless}}
                />
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>

        <div class="mission-totals">
        <strong>Total réussies :</strong> {{system.missions.totalCompleted}}
        |
        <strong>Total échouées :</strong> {{system.missions.totalFailed}}
        </div>
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="progression">
      <section class="panel">
        <h2>Progression de rang</h2>

        <div class="rank-summary">
          <div>
            <strong>Rang actuel</strong>
            <span>{{rankProgression.currentLabel}}</span>
          </div>

          <div>
            <strong>Plafond de Bases</strong>
            <span>{{rankProgression.currentBaseCap}}</span>
          </div>

          {{#if rankProgression.next}}
            <div>
              <strong>Prochain rang</strong>
              <span>{{rankProgression.next.label}}</span>
            </div>

            <div>
              <strong>XP requise</strong>
              <span>{{rankProgression.next.xp}}</span>
            </div>
          {{else}}
            <div>
              <strong>Prochain rang</strong>
              <span>Rang maximal atteint</span>
            </div>
          {{/if}}
        </div>

        {{#if rankProgression.next}}
          <section class="rank-checks">
            <h3>Conditions de promotion</h3>

          {{#each rankProgression.checks as |check|}}
            <div class="rank-check {{#if check.passed}}passed{{else}}failed{{/if}}">
              <span class="rank-check-status">
                {{#if check.passed}}✓{{else}}✗{{/if}}
              </span>

              <div class="rank-check-content">
                <strong>{{check.label}}</strong>
                <span>{{check.detail}}</span>
              </div>
            </div>
          {{/each}}

          {{#if isGM}}
            <button type="button" class="rank-promote" {{#unless rankProgression.canPromote}}disabled{{/unless}}>
              Valider le passage au rang suivant
            </button>
          {{else}}
            <p class="muted">Seul le MJ peut valider un passage de rang.</p>
          {{/if}}
          </section>
        {{else}}
          <p class="muted">Ce personnage a atteint le sommet officiel de la hiérarchie ninja.</p>
        {{/if}}
      </section>
    </div>

  </section>
</form>