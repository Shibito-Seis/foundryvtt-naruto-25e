<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header item-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />

    <div class="header-fields">
      <h1>
        <input name="name" type="text" value="{{item.name}}" placeholder="Nom" />
      </h1>

      <div class="item-type-pill">
        Type : {{item.type}}
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="main">Principal</a>
    <a class="item" data-tab="description">Description</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="main">
      {{#if isTechnique}}
        <section class="panel">
          <h2>Technique / Jutsu</h2>

          <div class="item-grid two-columns">
            <label>
              Famille
              <select name="system.family">
                <option value="">—</option>
                {{#each techniqueFamilies as |family|}}
                  <option value="{{family.key}}" {{#if family.selected}}selected{{/if}}>
                    {{family.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Domaine / Nature
              <input name="system.domain" type="text" value="{{system.domain}}" placeholder="Katon, Suiton, Kage..." />
            </label>

            <label>
              Rang
              <select name="system.rank">
                <option value="">—</option>
                {{#each techniqueRanks as |rank|}}
                  <option value="{{rank.key}}" {{#if rank.selected}}selected{{/if}}>
                    {{rank.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Niveau
              <input name="system.level" type="number" value="{{system.level}}" min="1" />
            </label>

            <label>
              Action
              <select name="system.actionType">
                {{#each techniqueActionTypes as |action|}}
                  <option value="{{action.key}}" {{#if action.selected}}selected{{/if}}>
                    {{action.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label>
              Base
              <select name="system.base">
                <option value="">—</option>
                {{#each baseOptions as |base|}}
                  <option value="{{base.key}}" {{#if base.selected}}selected{{/if}}>
                    {{base.label}}
                  </option>
                {{/each}}
              </select>
            </label>

            <label class="wide">
              Compétence liée
              <select name="system.skill">
                <option value="">— Choisir une compétence —</option>
                {{#each skillOptions as |skill|}}
                  <option value="{{skill.key}}" {{#if skill.selected}}selected{{/if}}>
                    {{skill.label}}
                  </option>
                {{/each}}
              </select>
            </label>
          </div>
        </section>

        <section class="panel">
          <h2>Paramètres</h2>

          <div class="item-grid two-columns">
            <label>
              Coût Chakra
              <input name="system.chakra.initial" type="number" value="{{system.chakra.initial}}" min="0" />
            </label>

            <label>
              Entretien Chakra
              <input name="system.chakra.maintenance" type="number" value="{{system.chakra.maintenance}}" min="0" />
            </label>

            <label>
              Portée
              <input name="system.range" type="text" value="{{system.range}}" />
            </label>

            <label>
              Durée
              <input name="system.duration" type="text" value="{{system.duration}}" />
            </label>

            <label>
              Cible
              <input name="system.target" type="text" value="{{system.target}}" />
            </label>

            <label>
              Zone
              <input name="system.area" type="text" value="{{system.area}}" />
            </label>

            <label>
                Formule de dégâts
                <input name="system.damage.formula" type="text" value="{{system.damage.formula}}" placeholder="Ex : 1d6, 2d6 + NIN, TAI + 2..." />
            </label>

            <label>
                Type de dégâts
                <select name="system.damage.type">
                    {{#each damageTypes as |type|}}
                        <option value="{{type.key}}" {{#if type.selected}}selected{{/if}}>
                            {{type.label}}
                        </option>
                    {{/each}}
                </select>
            </label>

            <label class="wide">
              Évolution / scaling
              <input name="system.damage.scaling" type="text" value="{{system.damage.scaling}}" />
            </label>

            <label class="wide">
              Texte Chakra
              <input name="system.chakra.text" type="text" value="{{system.chakra.text}}" />
            </label>
          </div>
        </section>

        <section class="panel">
          <h2>Jet</h2>

          <div class="item-grid two-columns">
            <label>
              Jet activé
              <input name="system.roll.enabled" type="checkbox" {{#if system.roll.enabled}}checked{{/if}} />
            </label>

            <label>
              Seuil par défaut
              <input name="system.roll.defaultDifficulty" type="number" value="{{system.roll.defaultDifficulty}}" min="0" />
            </label>

            <label>
              Jet opposé
              <input name="system.roll.opposed" type="checkbox" {{#if system.roll.opposed}}checked{{/if}} />
            </label>
          </div>

            <hr />

            <h3>Prérequis</h3>

            <div class="item-grid two-columns">
                <label>
                    Prérequis strict
                    <input name="system.prerequisites.strict" type="checkbox" {{#if system.prerequisites.strict}}checked{{/if}} />
                </label>

                <label>
                    Type de prérequis
                    <select name="system.prerequisites.type">
                        {{#each techniquePrerequisiteTypes as |type|}}
                            <option value="{{type.key}}" {{#if type.selected}}selected{{/if}}>
                                {{type.label}}
                            </option>
                        {{/each}}
                    </select>
                </label>

                <label>
                    Valeur du prérequis
                    <input
                        name="system.prerequisites.value"
                        type="text"
                        value="{{system.prerequisites.value}}"
                        placeholder="Ex : uchiha, hachimon, katon, hasMangekyoSharingan..."
                    />
                </label>

                <label>
                    Rang / seuil requis
                    <input name="system.prerequisites.masteryRank" type="number" value="{{system.prerequisites.masteryRank}}" min="0" />
                </label>

                <label>
                    Validation MJ du prérequis
                    <input name="system.prerequisites.validated" type="checkbox" {{#if system.prerequisites.validated}}checked{{/if}} />
                </label>

                <label class="wide">
                    Texte de prérequis
                    <input name="system.prerequisites.text" type="text" value="{{system.prerequisites.text}}" placeholder="Ex : Clan Uchiha, Mangekyō Sharingan éveillé, Lignée 5..." />
                </label>

                <p class="wide formula-hint">
                    Valeurs utiles : clan <code>uchiha</code>, <code>hyuga</code>, <code>senju</code> ; affinité <code>katon</code>, <code>suiton</code> ; option MJ <code>hasMangekyoSharingan</code>, <code>hasEternalMangekyoSharingan</code>, <code>hasSenjuCells</code>, <code>hasRinnegan</code>, <code>hasTenseigan</code>.
                </p>
            </div>

          <button type="button" class="technique-roll" {{#unless system.roll.enabled}}disabled{{/unless}}>
            Lancer la technique
          </button>

          <p class="formula-hint">
            Jet : 1d10 explosif + total de la compétence liée.
          </p>
        </section>
      {{else}}
        {{#if isConsommable}}
          <section class="panel">
            <h2>Consommable</h2>

            <div class="item-grid two-columns">
              <label>
                Sous-type
                <select name="system.subtype">
                  {{#each consumableSubtypes}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>

              <label>
                Quantité par défaut
                <input name="system.quantity" type="number" value="{{system.quantity}}" min="1" />
              </label>

              <label>
                Valeur
                <input name="system.value" type="number" value="{{system.value}}" min="0" />
              </label>

              <label>
                Poids
                <input name="system.weight" type="number" value="{{system.weight}}" min="0" step="0.01" />
              </label>

              <hr />

              <label>
                Type d’effet
                <select name="system.useEffect.type">
                  {{#each consumableEffectTypes}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>

              <label>
                Ressource ciblée
                <select name="system.useEffect.resource">
                  {{#each consumableResources}}
                    <option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                  {{/each}}
                </select>
              </label>

              <label>
                Montant
                <input name="system.useEffect.amount" type="number" value="{{system.useEffect.amount}}" min="0" />
              </label>

              <label>
                Consommé à l’usage
                <input name="system.useEffect.consumeOnUse" type="checkbox" {{#if system.useEffect.consumeOnUse}}checked{{/if}} />
              </label>

              <label class="wide">
                Texte d’effet
                <textarea name="system.useEffect.text">{{system.useEffect.text}}</textarea>
              </label>

              <p class="wide formula-hint">
                Exemple : une Pilule de Chakra mineure utilise
                <code>Restaurer une ressource</code>,
                ressource <code>Chakra</code>,
                montant <code>25</code>.
              </p>
            </div>
          </section>
        {{else}}
          <section class="panel">
            <h2>Item</h2>
            <p class="muted">
              Fiche générique provisoire. Les fiches détaillées arriveront dans une prochaine version.
            </p>
          </section>
        {{/if}}
      {{/if}}
    </div>

    <div class="tab" data-group="primary" data-tab="description">
        <section class="panel">
            <h2>Description</h2>
            <textarea name="system.description">{{system.description}}</textarea>
        </section>

        {{#if isTechnique}}
            <section class="panel">
                <h2>Effet</h2>
                <textarea name="system.effect">{{system.effect}}</textarea>
            </section>
        {{/if}}
    </div>
  </section>
</form>